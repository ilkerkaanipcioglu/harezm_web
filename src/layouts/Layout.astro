---
export interface Props {
  title: string;
  lang?: 'tr' | 'en';
}

const { title, lang = 'tr' } = Astro.props;
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html class="scroll-smooth" lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Harezm Technology</title>
    <meta name="description" content="Harezm Technology — SAP Danışmanlık & Finansal Mimari | Istanbul" />
    
    <!-- Theme: track OS preference dynamically -->
    <script is:inline>
      (function() {
        const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
        
        function applyTheme() {
          const stored = localStorage.getItem('harezm-theme');
          const preferred = mediaQuery.matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', stored || preferred);
        }
        
        applyTheme();

        // If user changes Windows setting, instantly apply it and override manual toggle
        mediaQuery.addEventListener('change', (e) => {
          localStorage.removeItem('harezm-theme');
          document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
        });
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg text-text-main font-sans antialiased selection:bg-plum/20 selection:text-plum">
    <Header lang={lang} />
    <main>
        <slot />
    </main>
    <Footer lang={lang} />
    
    <!-- Custom Contact Panel (Appears when Chatwoot opens) -->
    <div id="social-sidebar" class="fixed right-[400px] bottom-[100px] lg:right-[430px] z-[99999] flex-col gap-4 hidden transition-all duration-500 opacity-0 translate-x-12 sm:flex pointer-events-none">
        <a href="https://wa.me/905332388975" target="_blank" class="w-16 h-16 rounded-2xl bg-bg2 border border-border-main flex items-center justify-center text-text-main hover:bg-[#25D366] hover:text-white transition-all shadow-2xl group relative pointer-events-auto hover:scale-105" title="WhatsApp">
            <svg class="w-8 h-8 fill-current text-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            <span class="absolute right-[calc(100%+16px)] bg-bg2 text-text-main border border-border-main px-4 py-2 rounded-xl text-sm font-medium whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none drop-shadow-xl flex flex-col items-end">
                <span class="text-[10px] text-text-40 uppercase tracking-widest mb-0.5" id="lbl-wa-1">Doğrudan Ekibe Yazın</span>
                <span id="lbl-wa-2">WhatsApp İletişim</span>
            </span>
        </a>
        <a href="https://t.me/+905332388975" target="_blank" class="w-16 h-16 rounded-2xl bg-bg2 border border-border-main flex items-center justify-center text-text-main hover:bg-[#26A5E4] hover:text-white transition-all shadow-2xl group relative pointer-events-auto hover:scale-105" title="Telegram">
            <svg class="w-8 h-8 fill-current text-current" viewBox="0 0 24 24"><path d="m20.665 3.717-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785l3.019-14.228c.309-1.239-.473-1.8-1.282-1.434z"/></svg>
            <span class="absolute right-[calc(100%+16px)] bg-bg2 text-text-main border border-border-main px-4 py-2 rounded-xl text-sm font-medium whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none drop-shadow-xl flex flex-col items-end">
                <span class="text-[10px] text-text-40 uppercase tracking-widest mb-0.5" id="lbl-tg-1">Doğrudan Ekibe Yazın</span>
                <span id="lbl-tg-2">Telegram</span>
            </span>
        </a>
        <a href="https://www.linkedin.com/in/ilkerkaan/" target="_blank" class="w-16 h-16 rounded-2xl bg-bg2 border border-border-main flex items-center justify-center text-text-main hover:bg-[#0077b5] hover:text-white transition-all shadow-2xl group relative pointer-events-auto hover:scale-105" title="LinkedIn">
            <svg class="w-8 h-8 fill-current text-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            <span class="absolute right-[calc(100%+16px)] bg-bg2 text-text-main border border-border-main px-4 py-2 rounded-xl text-sm font-medium whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none drop-shadow-xl flex flex-col items-end">
                <span class="text-[10px] text-text-40 uppercase tracking-widest mb-0.5" id="lbl-in-1">Kurucuya Ulaşın</span>
                <span id="lbl-in-2">Ilker Kaan İpcioğlu</span>
            </span>
        </a>
        <a href="mailto:info@harezm.com.tr" class="w-16 h-16 rounded-2xl bg-bg2 border border-border-main flex items-center justify-center text-text-main hover:bg-plum hover:text-white transition-all shadow-2xl group relative pointer-events-auto hover:scale-105" title="Email">
            <span class="material-symbols-outlined text-4xl">mail</span>
            <span class="absolute right-[calc(100%+16px)] bg-bg2 text-text-main border border-border-main px-4 py-2 rounded-xl text-sm font-medium whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none drop-shadow-xl flex flex-col items-end">
                <span class="text-[10px] text-text-40 uppercase tracking-widest mb-0.5" id="lbl-em-1">Resmi İletişim</span>
                <span id="lbl-em-2">info@harezm.com.tr</span>
            </span>
        </a>
    </div>

    <!-- Chatwoot Widget -->
    <script is:inline>
      (function(d,t) {
        var BASE_URL="https://app.chatwoot.com";
        var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
        g.src=BASE_URL+"/packs/js/sdk.js";
        g.async = true;
        s.parentNode.insertBefore(g,s);
        g.onload=function(){
          window.chatwootSDK.run({
            websiteToken: 'XirjPKdt4udsdmUaog34t6GP',
            baseUrl: BASE_URL
          })
        }
      })(document,"script");

      // Dynamic translations based on html lang attribute
      window.addEventListener("DOMContentLoaded", function () {
        const lang = document.documentElement.lang || 'tr';
        if (lang === 'en') {
            document.getElementById('lbl-wa-1').innerText = "Message Direct";
            document.getElementById('lbl-wa-2').innerText = "WhatsApp";
            document.getElementById('lbl-tg-1').innerText = "Message Direct";
            document.getElementById('lbl-tg-2').innerText = "Telegram";
            document.getElementById('lbl-in-1').innerText = "Contact Founder";
            document.getElementById('lbl-em-1').innerText = "Official Email";
        }
      });

      window.addEventListener("chatwoot:opened", function () {
        const sidebar = document.getElementById('social-sidebar');
        if(sidebar && window.innerWidth >= 640) { 
            sidebar.classList.remove('hidden');
            setTimeout(() => {
                sidebar.classList.remove('opacity-0', 'translate-x-12');
            }, 50);
        }
      });
      window.addEventListener("chatwoot:closed", function () {
        const sidebar = document.getElementById('social-sidebar');
        if(sidebar) {
            sidebar.classList.add('opacity-0', 'translate-x-12');
            setTimeout(() => {
                sidebar.classList.add('hidden');
            }, 500);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  /* === BASE === */
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-weight: 300;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  /* === TYPOGRAPHY === */
  .display-lg {
    font-family: var(--font-serif);
    line-height: var(--text-h1--line-height);
    letter-spacing: var(--text-h1--letter-spacing);
  }

  .text-secondary { color: var(--text-70); }
  .text-hint { color: var(--text-40); }

  .max-w-text { max-width: 600px; }
  .max-w-container { max-width: var(--max-w); }

  /* === ICONS === */
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  /* === NAV GLASSMORPHISM === */
  .glass-nav {
    background: transparent;
    transition: background-color 0.3s ease, backdrop-filter 0.3s ease;
  }
  .glass-nav.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* === CARDS === */
  .glass-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    box-shadow: var(--card-shadow);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .glass-card:hover {
    background: var(--bg3);
    border-color: var(--border-2);
  }

  /* === ANIMATIONS (minimal, purposeful) === */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }

  /* === GRADIENT TEXT === */
  .gradient-text {
    background: linear-gradient(135deg, var(--teal) 0%, var(--plum) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* === SCROLLBAR === */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-40); }

  /* === SECTION === */
  section { position: relative; }
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--border) 50%, transparent 100%);
  }

  /* === SMOOTH SCROLL === */
  html { scroll-behavior: smooth; }
</style>
