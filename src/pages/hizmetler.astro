---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Hizmetler">
    <!-- HERO -->
    <section class="relative pt-40 pb-24 bg-on-background overflow-hidden">
        <div class="max-w-7xl mx-auto px-8 relative z-10">
            <div class="w-full md:w-3/4">
                <span class="inline-block px-4 py-1.5 rounded-full bg-primary-container/20 text-primary-fixed border border-primary-container/30 text-xs font-bold tracking-widest mb-8 uppercase">
                    SAP UZMANLIK HİZMETLERİ
                </span>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-white leading-tight tracking-tight mb-8">
                    Finansal Sistemlerinizi<br/><span class="text-primary-container">Otomatize Ediyoruz.</span>
                </h1>
                <p class="text-lg md:text-xl text-slate-400 max-w-2xl leading-relaxed mb-16">
                    Yapay zeka ve SAP mimarisiyle finansal operasyonlarınızı sadeleştiriyor, sınır ötesi dönüşüm stratejinizi güvence altına alıyoruz.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white/5 border border-white/10 p-8 rounded-md backdrop-blur-sm group hover:border-primary-container/50 transition-all">
                        <div class="text-4xl font-bold text-white mb-2 font-headline group-hover:text-primary-container transition-colors">100+</div>
                        <div class="text-sm font-medium text-slate-400 tracking-wider uppercase">Başarılı Proje</div>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-md backdrop-blur-sm group hover:border-primary-container/50 transition-all">
                        <div class="text-4xl font-bold text-white mb-2 font-headline group-hover:text-primary-container transition-colors">15+</div>
                        <div class="text-sm font-medium text-slate-400 tracking-wider uppercase">Yıllık Tecrübe</div>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-md backdrop-blur-sm group hover:border-primary-container/50 transition-all">
                        <div class="text-4xl font-bold text-white mb-2 font-headline group-hover:text-primary-container transition-colors">7/24</div>
                        <div class="text-sm font-medium text-slate-400 tracking-wider uppercase">Teknik Destek</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary/10 to-transparent pointer-events-none"></div>
    </section>

    <!-- SERVICES BENTO GRID -->
    <section class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="text-4xl font-bold font-headline text-on-background mb-4">Stratejik Odak Alanlarımız</h2>
                    <div class="h-1.5 w-24 bg-primary"></div>
                </div>
                <p class="text-on-secondary-container max-w-md text-sm leading-relaxed">
                    Yüksek hacimli finansal süreçleri optimize ediyor ve veriye dayalı karar alma algoritmaları kuruyoruz.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[280px]">
                <!-- Card 1: SAP FI & CO / Material Ledger (Merged) -->
                <div class="md:col-span-8 md:row-span-2 bg-primary p-10 rounded-md flex flex-col justify-between text-white relative overflow-hidden group">
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-4">
                            <span class="material-symbols-outlined text-5xl group-hover:animate-icon-float">account_balance</span>
                            <span class="px-3 py-1 bg-white/20 text-white rounded-full text-[10px] font-bold tracking-tight">Finsoft'un Amiral Gemisi</span>
                        </div>
                        <h3 class="text-3xl font-bold font-headline mb-2">SAP FI, CO & Material Ledger</h3>
                        <p class="text-white/60 text-sm mb-5">Finansal muhasebe, maliyet kontrolü ve gerçek maliyet hesaplamasını tek bir yapıda sunuyoruz.</p>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-3 text-white/80 text-xs">
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-2">FI — Finansal Muhasebe</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Defter-i Kebir (New GL)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Borçlar & Alacaklar (AP/AR)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Duran Varlık Yönetimi (AA)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Banka Muhasebesi</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Vergi & e-Dönüşüm</span></div>
                                </div>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-2">CO — Kontroling</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Maliyet Merkezi Muhasebesi</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Dahili Sipariş Yönetimi</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Ürün Maliyetlendirme</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Kârlılık Analizi (CO-PA)</span></div>
                                </div>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-2">Material Ledger</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Gerçek Maliyet (Actual Costing)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Çoklu Para Birimi Değerleme</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Çok Seviyeli Fiyat Belirleme</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Stok Yeniden Değerleme</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Card 5: S/4HANA -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between border border-outline-variant/20 group hover:bg-primary hover:text-white transition-all duration-500">
                    <div>
                        <span class="material-symbols-outlined text-on-background group-hover:text-white text-4xl mb-4 group-hover:animate-icon-bounce">rocket_launch</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background group-hover:text-white">SAP S/4HANA Dönüşüm</h3>
                        <p class="text-on-secondary-container group-hover:text-white/80 text-sm leading-relaxed">Grow with SAP & Rise with SAP — Greenfield ve Brownfield yaklaşımlarıyla yeni nesil ERP dünyasına sorunsuz geçiş.</p>
                    </div>
                    <a href="/s4hana" class="inline-flex items-center gap-2 font-bold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Detayları İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 6: PS & BPC -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group">
                    <div>
                        <span class="material-symbols-outlined text-on-background text-4xl mb-4 group-hover:animate-icon-wiggle">schema</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background">SAP PS, IM &amp; BPC</h3>
                        <p class="text-on-surface-variant text-sm leading-relaxed">Yatırım yönetimi, proje planlaması ve bütçe konsolidasyonu süreçlerinizi SAP Project System, Investment Management ve Business Planning & Consolidation modülleriyle entegre ediyoruz.</p>
                    </div>
                </div>
                <!-- Card 7: AMS Support & Outsourcing -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between border border-outline-variant/20 group">
                    <div>
                        <span class="material-symbols-outlined text-primary text-4xl mb-4 group-hover:animate-icon-wiggle">engineering</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background">Dış Kaynak ve Stratejik AMS Desteği</h3>
                        <p class="text-on-surface-variant text-sm leading-relaxed mb-4">Kurumsal SAP projeleriniz ve kesintisiz operasyonlarınız için kıdemli danışman ekibimizle uçtan uca, esnek ve yüksek kaliteli SLA kurguları yönetiyoruz.</p>
                    </div>
                </div>
                <!-- Card 8: SAP RE-FX -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border-t-4 border-primary">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-float">real_estate_agent</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background group-hover:text-white">SAP RE-FX Gayrimenkul</h3>
                        <p class="text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed">Gayrimenkul portföy yönetimi, kira kontratları, bakım/onarım ve FI/CO entegrasyonu ile uçtan uca çözüm.</p>
                    </div>
                    <a href="/sap-refx" class="inline-flex items-center gap-2 font-bold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Detayları İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 9: SAP & OpenText -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border border-outline-variant/20">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-float">auto_awesome</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background group-hover:text-white">SAP & OpenText</h3>
                        <p class="text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed">Yapay zeka destekli doküman yönetimi, VIM fatura otomasyonu ve SAP entegrasyonu ile dijital dönüşüm.</p>
                    </div>
                    <a href="/sap-opentext" class="inline-flex items-center gap-2 font-bold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Detayları İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 10: SAP Check-Up -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border-t-4 border-primary">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-bounce">health_and_safety</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background group-hover:text-white">Sistem Optimizasyonu & Check-Up</h3>
                        <p class="text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed">SAP Best Practice uyum analiziyle finansal süreçlerinizdeki gizli darboğazları tespit ediyor ve otomasyon haritanızı çıkarıyoruz.</p>
                    </div>
                    <a href="/sap-checkup" class="inline-flex items-center gap-2 font-bold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Detayları İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 11: Danışmanlık -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border border-outline-variant/20">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-wiggle">psychology</span>
                        <h3 class="text-xl font-bold font-headline mb-3 text-on-background group-hover:text-white">Danışmanlık Hizmetleri</h3>
                        <p class="text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed">IT stratejisi, dijital dönüşüm, yapay zeka danışmanlığı ve süreç optimizasyonu ile işinizi geleceğe taşıyın.</p>
                    </div>
                    <a href="/danismanlik" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Detayları İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 12: SAP Cash Management -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border-t-4 border-primary">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-float">account_balance_wallet</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-on-background group-hover:text-white">SAP Cash Management</h3>
                        <p class="text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed">Nakit görünürlüğünü %100'e çıkarın, banka hesaplarınızı ve likidite tahminlerinizi tek merkezden anlık yönetin.</p>
                    </div>
                    <a href="/sap-cash-management" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Detayları İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 13: SAP TRM -->
                <div class="md:col-span-12 md:row-span-1 bg-surface-container-highest p-10 rounded-2xl flex flex-col md:flex-row justify-between items-center group hover:bg-primary hover:text-white transition-all duration-500 border border-outline-variant/20 relative overflow-hidden">
                    <div class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-primary/10 to-transparent pointer-events-none"></div>
                    <div class="md:w-2/3 relative z-10">
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-5xl mb-4 group-hover:animate-icon-wiggle">monitoring</span>
                        <h3 class="text-2xl font-bold font-headline mb-3 text-on-background group-hover:text-white">SAP Treasury and Risk Management</h3>
                        <p class="text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed md:pr-12">İşletme Sermayesini Optimize Edin, Nakit Verimliliğinde %30 Artış Sağlayın. Finansal veri dokusu üzerinde likidite, ödeme ve risklerinizi tek merkezden yönetin.</p>
                    </div>
                    <div class="md:w-1/3 flex md:justify-end mt-8 md:mt-0 relative z-10">
                        <a href="/sap-trm" class="inline-flex items-center gap-2 font-bold text-sm bg-primary text-white group-hover:bg-white group-hover:text-primary px-8 py-4 rounded-xl hover:shadow-xl hover:-translate-y-1 transition-all duration-300">Hemen İncele <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA SECTION -->
    <section class="py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-8">
            <div class="bg-primary rounded-md p-12 md:p-20 text-center relative overflow-hidden">
                <h2 class="text-3xl md:text-5xl font-semibold font-headline text-white mb-8 relative z-10">Stratejinizi Birlikte İnşa Edelim</h2>
                <p class="text-primary-fixed max-w-2xl mx-auto mb-12 text-lg relative z-10">İşletmenizin finansal darboğazlarını detaylı bir analizle değerlendirelim ve otomasyon hedeflerinizi doğru planla hayata geçirelim.</p>
                <div class="flex flex-col md:flex-row gap-6 justify-center relative z-10">
                    <a href="/iletisim" class="bg-white text-primary px-10 py-4 rounded-md font-semibold text-sm hover:shadow-2xl hover:-translate-y-1 transition-all shadow-xl">
                        Değerlendirme Başlatın
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
