---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ana Sayfa">
    <!-- Hero Section -->
    <header class="relative pt-32 pb-20 px-8 md:px-12 overflow-hidden bg-surface bg-grid">
        <!-- Subtle gradients -->
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary-container/10 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
            <div class="lg:col-span-7 animate-fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 text-primary text-xs font-semibold mb-8 tracking-wider uppercase border border-primary/15">
                    <span class="material-symbols-outlined text-sm">verified</span>
                    SAP FİNANS VE LOKALİZASYON UZMANLIĞI
                </div>
                <h1 class="display-lg text-5xl xl:text-7xl 2xl:text-8xl mb-8 text-on-background">
                    SAP ve Yapay Zeka ile <br/>
                    <span class="gradient-text italic">Finansal Dönüşüm</span>
                </h1>
                <p class="text-lg text-on-surface-variant max-w-2xl mb-12 font-body leading-relaxed font-light">
                    Karmaşık finansal süreçleri sadeleştiriyor, sınır ötesi operasyonlarınızı ve SAP dönüşümünüzü güvence altına alıyoruz. 15+ yıllık deneyimle CFO ofisini stratejik karar merkezine dönüştürün.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="/hizmetler" class="bg-primary text-on-primary px-8 py-4 rounded-lg font-semibold text-base flex items-center gap-2 hover:bg-primary-container hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 group">
                        Yaklaşımımızı İnceleyin
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                    <a href="/iletisim" class="bg-white ghost-border text-on-background px-8 py-4 rounded-lg font-semibold text-base hover:shadow-lg transition-all duration-300">
                        Stratejinizi Değerlendirelim
                    </a>
                </div>
            </div>
            <div class="lg:col-span-5 relative mt-12 lg:mt-0 z-20 animate-fade-right delay-2">
                <!-- Main Image -->
                <div class="w-full aspect-[4/5] md:aspect-square rounded-2xl overflow-hidden relative shadow-2xl border border-white/40">
                    <img alt="Abstract Financial Tech" class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop"/>
                    <div class="absolute inset-0 bg-gradient-to-tr from-primary/60 via-primary/15 to-transparent mix-blend-multiply"></div>
                </div>
                
                <!-- Floating Stat Card -->
                <div class="absolute -bottom-6 -left-4 md:-left-12 bg-white/95 backdrop-blur-xl p-6 md:p-8 rounded-2xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.12)] border border-white max-w-[280px] card-hover animate-scale-in delay-4">
                    <div class="flex items-center gap-4 mb-3">
                        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-primary text-3xl">public</span>
                        </div>
                        <div class="text-primary text-5xl font-semibold font-headline tracking-tighter">100+</div>
                    </div>
                    <div class="text-on-surface font-semibold text-sm leading-snug">Başarıyla Tamamlanmış<br/>Global Entegrasyon</div>
                </div>

                <!-- Secondary Floating Card -->
                <div class="absolute top-12 -right-4 md:-right-8 bg-on-background/95 backdrop-blur-md py-4 px-6 rounded-2xl shadow-2xl border border-slate-700/50 flex items-center gap-4 card-hover animate-scale-in delay-5">
                    <div class="bg-primary/20 p-2.5 rounded-xl text-primary-container flex items-center justify-center">
                        <span class="material-symbols-outlined text-xl">workspace_premium</span>
                    </div>
                    <span class="text-white font-semibold text-sm tracking-wide">%40 Daha Hızlı Finansal Kapanış</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Problem-Solution Section -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface">
        <div class="max-w-[1920px] mx-auto">
            <div class="mb-16 text-center">
                <h2 class="display-lg text-4xl md:text-5xl mb-4">Manuel Süreçlerden <span class="gradient-text">Otomasyona</span></h2>
                <p class="text-on-surface-variant max-w-2xl mx-auto font-light">SAP mimarisi ve AI destekli yaklaşımlarla finansal operasyonlardaki darboğazları çözüyor, veri odaklı bir altyapı kuruyoruz.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Problem Card -->
                <div class="bg-surface-container-low p-10 md:p-12 rounded-2xl card-hover border border-outline-variant/30">
                    <div class="flex items-center gap-3 text-slate-500 mb-8">
                        <div class="w-10 h-10 rounded-xl bg-slate-200/60 flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-600">analytics</span>
                        </div>
                        <span class="font-semibold tracking-widest uppercase text-xs text-slate-600">Mevcut Zorluklar</span>
                    </div>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <span class="text-slate-400 mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">Yanlış Maliyetleme</h4>
                                <p class="text-on-surface-variant text-sm font-light">Hatalı CO yapılandırması sonucu ürün karlılığının şeffaf izlenememesi.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="text-slate-400 mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">Veri Dağınıklığı</h4>
                                <p class="text-on-surface-variant text-sm font-light">Farklı sistemlerden gelen uyumsuz finansal verilerin konsolidasyon zorluğu.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="text-slate-400 mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">Uyumsuz Raporlama</h4>
                                <p class="text-on-surface-variant text-sm font-light">Manuel süreçler ve tutarsız veriler ile karar alma mekanizmalarının zayıflaması.</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <!-- Solution Card -->
                <div class="bg-primary p-10 md:p-12 rounded-2xl text-white card-hover">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center">
                            <span class="material-symbols-outlined text-white">check_circle</span>
                        </div>
                        <span class="font-semibold tracking-widest uppercase text-xs text-white/80">Finsoft Çözümü</span>
                    </div>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">Doğru CO Tasarımı</h4>
                                <p class="text-white/70 text-sm">Operasyonel mükemmellik için uçtan uca karlılık analizi ve maliyet akışı.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">Merkezi Finansal Yönetim</h4>
                                <p class="text-white/70 text-sm">S/4HANA ile gerçek zamanlı raporlama ve tek veri kaynağı güvenilirliği.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">Otomatik Uyum</h4>
                                <p class="text-white/70 text-sm">e-Fatura, e-Defter ve mevzuat gereksinimleri ile tam entegrasyon.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section (Bento Grid) -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface-container-lowest">
        <div class="max-w-[1920px] mx-auto">
            <div class="mb-12">
                <h2 class="display-lg text-4xl mb-3">Stratejik Uzmanlık Alanları</h2>
                <p class="text-on-surface-variant font-light max-w-xl">İşletmenizin dijital dönüşüm yolculuğunu stratejik çözümlerle destekliyoruz.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Main Service -->
                <div class="md:col-span-2 bg-surface-container-low p-10 rounded-2xl group hover:bg-primary hover:text-on-primary transition-all duration-500 flex flex-col justify-between h-[400px] card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-float">account_balance</span>
                        <h3 class="text-3xl font-semibold mb-4">SAP FI/CO Otomasyonu</h3>
                        <p class="text-on-surface-variant group-hover:text-on-primary/80 max-w-md font-light">Defter-i Kebir, Borçlar/Alacaklar Muhasebesi, Duran Varlıklar ve Masraf Yeri Muhasebesi gibi kritik süreçlerde tam entegrasyon.</p>
                    </div>
                    <a class="inline-flex items-center gap-2 font-semibold group-hover:underline underline-offset-4 text-sm" href="/hizmetler">
                        Detayları İncele <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_outward</span>
                    </a>
                </div>
                <!-- Localization Highlight -->
                <div class="bg-on-background p-10 rounded-2xl flex flex-col justify-between text-white card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl text-primary-container mb-6 group-hover:animate-icon-wiggle">flag</span>
                        <h3 class="text-2xl font-semibold mb-4">Türkiye Lokalizasyonu</h3>
                        <p class="text-slate-400 text-sm font-light">E-Fatura, E-Defter ve Türk mevzuatına tam uyumlu SAP çözümleriyle yasal risklerinizi sıfıra indirin.</p>
                    </div>
                    <span class="bg-primary/20 text-primary-container self-start px-3 py-1 rounded-full text-xs font-semibold uppercase">Kritik Hizmet</span>
                </div>
                <!-- Global Projects -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-on-background hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-float">public</span>
                        <h3 class="text-2xl font-semibold mb-4">Dönüşüm &amp; Global Projeler</h3>
                        <p class="text-on-surface-variant group-hover:text-slate-300 text-sm font-light">Roll-out projeleri ve sistem dönüşümlerinde küresel tecrübe.</p>
                    </div>
                </div>
                <!-- Support & Outsourcing -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-on-background hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-wiggle">engineering</span>
                        <h3 class="text-2xl font-semibold mb-4">Danışman Kaynağı & Destek</h3>
                        <p class="text-on-surface-variant group-hover:text-slate-300 text-sm font-light">Proje ve operasyonlarınız için kıdemli SAP danışmanlarını dış kaynak olarak sağlıyoruz.</p>
                    </div>
                </div>
                <!-- S/4HANA -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-on-background hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-bounce">rocket_launch</span>
                        <h3 class="text-2xl font-semibold mb-4">S/4HANA Geçişi</h3>
                        <p class="text-on-surface-variant group-hover:text-slate-300 text-sm font-light">Eski sistemlerinizden S/4HANA'ya güvenli ve hızlı veri transferi.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Finsoft -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-on-background text-white relative overflow-hidden">
        <!-- Decorative -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[150px] pointer-events-none"></div>

        <div class="max-w-[1920px] mx-auto relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                <div>
                    <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">NEDEN BİZ?</span>
                    <h2 class="display-lg text-4xl md:text-5xl mb-8">Neden <span class="text-primary-container">Finsoft</span>?</h2>
                    <p class="text-slate-400 text-lg mb-12 font-light">Biz sadece yazılım kurmuyoruz; işinizin finansal mimarisini tasarlıyoruz.</p>
                    <div class="grid grid-cols-1 gap-8">
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-float">psychology</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">Derin Teknik Bilgi</h4>
                                <p class="text-slate-400 font-light">SAP FI/CO modüllerinde derinlemesine uzmanlaşmış kıdemli danışman kadrosu.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-wiggle">diversity_3</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">Butik Yaklaşım</h4>
                                <p class="text-slate-400 font-light">Her işletmenin ihtiyacına özel, kalıplaşmış değil, terzi usulü çözümler.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-bounce">speed</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">Hızlı Devreye Alma</h4>
                                <p class="text-slate-400 font-light">Best-practice kütüphanemiz ile proje sürelerinde %30 tasarruf.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="relative">
                    <img alt="Technology Team" class="rounded-2xl grayscale opacity-40 border border-slate-700/50" src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=2070&auto=format&fit=crop"/>
                    <div class="absolute -bottom-8 -right-8 bg-primary p-10 rounded-2xl hidden md:block shadow-2xl shadow-primary/30">
                        <p class="text-2xl font-semibold italic leading-tight">"Karmaşıklığı <br/>Sadelikle <br/>Yönetiyoruz."</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- References Preview -->
    <section class="py-24 md:py-32 px-6 md:px-12 bg-surface">
        <div class="max-w-[1920px] mx-auto">
            <div class="text-center mb-16">
                <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">REFERANSLARIMIZ</span>
                <h2 class="display-lg text-3xl md:text-4xl">Bize Güvenen Markalar</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4 lg:gap-5">
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Aselsan" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=aselsan.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Aselsan</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Pfizer" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=pfizer.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Pfizer</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="TSKB" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=tskb.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">TSKB</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="EVYAP" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=evyap.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Evyap</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Ferrero" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=ferrero.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Ferrero</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Temsa" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=temsa.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Temsa</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Borçelik" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=borcelik.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Borçelik</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Hayat Holding" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=hayat.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Hayat Holding</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Wavin" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=wavin.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Wavin</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="UCB Pharma" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=ucb.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">UCB Pharma</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Ülker" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=ulker.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Ülker</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Philip Morris" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-slate-100" src="https://s2.googleusercontent.com/s2/favicons?domain=pmi.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Philip Morris</span>
