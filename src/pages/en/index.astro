---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/utils';
const lang = 'en' as const;
---

<Layout title="Home" lang={lang}>
    <!-- Hero Section -->
    <header class="relative pt-32 pb-20 px-8 md:px-12 flex flex-col justify-center min-h-[calc(100vh-80px)] overflow-hidden bg-bg border-b border-border-main">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-plum)_0%,_transparent_40%)] opacity-10 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-plum/5 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="max-w-container w-full mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
            <!-- Left Content (7/12) -->
            <div class="lg:col-span-7 animate-fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface text-text-70 text-label mb-8 border border-border">
                    <span class="material-symbols-outlined text-sm">verified</span>
                    SAP CERTIFIED PARTNER · ISTANBUL
                </div>
                
                <h1 class="display-lg text-4xl md:text-h1 mb-6">
                    Financial Control <br/> <em class="text-plum italic font-normal">Architecture</em>
                </h1>
                
                <p class="text-text-70 text-body-lg mb-10 font-light max-w-text">
                    We don't just build systems. We design your company's financial reality — liquidity, risk, compliance, and decision mechanisms under a single architecture.
                </p>
                
                <div class="flex flex-wrap gap-4">
                    <a href="/en/iletisim" class="bg-plum text-white px-8 py-4 rounded-lg font-medium text-ui hover:bg-plum-hover transition-colors">
                        Start Project
                    </a>
                    <a href="/en/hizmetler" class="bg-transparent text-text-main px-8 py-4 rounded-lg font-medium text-ui border border-border-main hover:bg-bg2 transition-colors inline-flex items-center gap-2">
                        Explore Services
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
            </div>

            <!-- Right Panel (5/12) - Trust Signals -->
            <div class="lg:col-span-5 animate-fade-left delay-2 border border-border rounded-xl p-8 lg:p-10 bg-bg2 relative overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-border)_0%,_transparent_60%)] opacity-20 pointer-events-none"></div>
                <h3 class="text-h4 mb-6 relative z-10">Industries We Serve</h3>
                
                <div class="flex flex-wrap gap-3 mb-8 relative z-10">
                    <span class="px-4 py-2 rounded-lg bg-bg text-text-70 text-sm border border-border">Pharma</span>
                    <span class="px-4 py-2 rounded-lg bg-bg text-text-70 text-sm border border-border">Defense</span>
                    <span class="px-4 py-2 rounded-lg bg-bg text-text-70 text-sm border border-border">FMCG</span>
                    <span class="px-4 py-2 rounded-lg bg-bg text-text-70 text-sm border border-border">Energy</span>
                    <span class="px-4 py-2 rounded-lg bg-bg text-text-70 text-sm border border-border">Automotive</span>
                </div>

                <div class="pt-6 border-t border-border flex items-center justify-between relative z-10">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-teal text-xl">architecture</span>
                        <div>
                            <p class="text-label text-text-40">SAP Certified Partner</p>
                            <p class="text-sm text-text-70 font-medium">Financial Tech Solutions</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Problem-Solution Section -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface">
        <div class="max-w-[1920px] mx-auto">
            <div class="mb-16 text-center">
                <h2 class="display-lg text-4xl md:text-5xl mb-4">{t('psSectionTitle', lang)}</h2>
                <p class="text-on-surface-variant max-w-2xl mx-auto font-light">{t('psSectionDesc', lang)}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Problem Card -->
                <div class="bg-surface-container-low p-10 md:p-12 rounded-2xl card-hover border border-outline-variant/30">
                    <div class="flex items-center gap-3 text-on-surface-variant mb-8">
                        <div class="w-10 h-10 rounded-xl bg-surface-variant flex items-center justify-center">
                            <span class="material-symbols-outlined text-outline">analytics</span>
                        </div>
                        <span class="font-semibold tracking-widest uppercase text-xs text-outline">{t('psProblems', lang)}</span>
                    </div>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <span class="text-on-surface-variant mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">{t('psP1Title', lang)}</h4>
                                <p class="text-on-surface-variant text-sm font-light">{t('psP1Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="text-on-surface-variant mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">{t('psP2Title', lang)}</h4>
                                <p class="text-on-surface-variant text-sm font-light">{t('psP2Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="text-on-surface-variant mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">Inconsistent Reporting</h4>
                                <p class="text-on-surface-variant text-sm font-light">Weakened decision-making mechanisms due to manual processes and inconsistent data.</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <!-- Solution Card -->
                <div class="bg-primary p-10 md:p-12 rounded-2xl text-white card-hover">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center">
                            <span class="material-symbols-outlined text-white">check_circle</span>
                        </div>
                        <span class="font-semibold tracking-widest uppercase text-xs text-white/80">{t('psSolutions', lang)}</span>
                    </div>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">{t('psS1Title', lang)}</h4>
                                <p class="text-white/70 text-sm">{t('psS1Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">{t('psS2Title', lang)}</h4>
                                <p class="text-white/70 text-sm">{t('psS2Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">Automated Compliance</h4>
                                <p class="text-white/70 text-sm">Full integration with e-Invoicing, e-Ledger, and regulatory requirements.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section (Bento Grid) -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface-container-lowest">
        <div class="max-w-[1920px] mx-auto">
            <div class="mb-12">
                <h2 class="display-lg text-4xl mb-3">{t('svcTitle', lang)}</h2>
                <p class="text-on-surface-variant font-light max-w-xl">We support your business's digital transformation journey with strategic solutions.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Main Service -->
                <div class="md:col-span-2 bg-surface-container-low p-10 rounded-2xl group hover:bg-primary hover:text-on-primary transition-all duration-500 flex flex-col justify-between h-[400px] card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-float">account_balance</span>
                        <h3 class="text-3xl font-semibold mb-4">{t('svcFiCoTitle', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-on-primary/80 max-w-md font-light">{t('svcFiCoDesc', lang)}</p>
                    </div>
                    <a class="inline-flex items-center gap-2 font-semibold group-hover:underline underline-offset-4 text-sm" href="/en/hizmetler">
                        {t('svcFiCoLink', lang)} <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_outward</span>
                    </a>
                </div>
                <!-- Localization Highlight -->
                <div class="bg-plum p-10 rounded-2xl flex flex-col justify-between text-white card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl text-white/80 mb-6 group-hover:animate-icon-wiggle">flag</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcLocTitle', lang)}</h3>
                        <p class="text-white/80 text-sm font-light">{t('svcLocDesc', lang)}</p>
                    </div>
                    <span class="bg-primary/20 text-primary-container self-start px-3 py-1 rounded-full text-xs font-semibold uppercase">{t('svcLocBadge', lang)}</span>
                </div>
                <!-- Global Projects -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-plum hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-float">public</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcGlobalTitle', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-white/90 text-sm font-light">{t('svcGlobalDesc', lang)}</p>
                    </div>
                </div>
                <!-- Support & Outsourcing -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-plum hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-wiggle">engineering</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcOutsourceTitle', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-white/90 text-sm font-light">{t('svcOutsourceDesc', lang)}</p>
                    </div>
                </div>
                <!-- S/4HANA -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-plum hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-bounce">rocket_launch</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcS4Title', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-white/90 text-sm font-light">{t('svcS4Desc', lang)}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Harezm -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-bg2 text-text-main relative overflow-hidden">
        <!-- Decorative -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[150px] pointer-events-none"></div>

        <div class="max-w-[1920px] mx-auto relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                <div>
                    <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">WHY US?</span>
                    <h2 class="display-lg text-4xl md:text-5xl mb-8">{t('whyTitle', lang)}</h2>
                    <p class="text-on-surface-variant text-lg mb-12 font-light">{t('whyDesc', lang)}</p>
                    <div class="grid grid-cols-1 gap-8">
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-float">psychology</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">{t('why1Title', lang)}</h4>
                                <p class="text-on-surface-variant font-light">{t('why1Desc', lang)}</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-wiggle">diversity_3</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">{t('why2Title', lang)}</h4>
                                <p class="text-on-surface-variant font-light">{t('why2Desc', lang)}</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-bounce">speed</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">{t('why3Title', lang)}</h4>
                                <p class="text-on-surface-variant font-light">{t('why3Desc', lang)}</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="relative aspect-square md:aspect-[4/3] rounded-2xl border border-outline-variant/10 bg-surface-container flex flex-col items-center justify-center p-12">
                     <span class="material-symbols-outlined text-[100px] text-primary/10 absolute top-10 right-10">format_quote</span>
                     <p class="text-3xl md:text-4xl font-semibold italic leading-relaxed text-on-surface text-center">"Managing <br/>Complexity <br/>with Simplicity."</p>
                </div>
            </div>
        </div>
    </section>


    <!-- Thought Leadership (Premium Insight) -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface border-t border-outline-variant/10">
        <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
                <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">{t('tlBadge', lang)}</span>
                <h2 class="display-lg text-4xl md:text-5xl mb-6">{t('tlTitle', lang)}</h2>
                <p class="text-on-surface-variant text-lg leading-relaxed font-light mb-8 max-w-xl">
                    {t('tlDesc', lang)}
                </p>
                <a href="/harezm_cfo_ajandasi.pdf" download class="inline-flex items-center gap-3 bg-plum text-white px-8 py-4 rounded-lg font-semibold text-sm hover:shadow-2xl hover:-translate-y-1 transition-all">
                    {t('tlBtn', lang)}
                    <span class="material-symbols-outlined text-base">download</span>
                </a>
            </div>
            <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent blur-3xl -z-10"></div>
                <div class="aspect-[4/3] rounded-2xl bg-surface-container-low border border-outline-variant/20 shadow-[-10px_20px_40px_rgba(0,0,0,0.05)] p-12 flex flex-col justify-between group">
                    <div>
                        <span class="material-symbols-outlined text-4xl text-primary mb-6">menu_book</span>
                        <h3 class="display-lg text-2xl md:text-3xl mb-4 group-hover:text-primary transition-colors">{t('tlBookTitle', lang)}</h3>
                        <p class="text-on-surface-variant font-light text-sm">{t('tlBookDesc', lang)}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-primary relative overflow-hidden">
        <!-- Decorative circles -->
        <div class="absolute -top-20 -right-20 w-[400px] h-[400px] bg-white/5 rounded-full pointer-events-none"></div>
        <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-white/5 rounded-full pointer-events-none"></div>

        <div class="max-w-4xl mx-auto text-center relative z-10">
            <h2 class="display-lg text-4xl md:text-6xl text-on-primary mb-8">{t('ctaTitle', lang)}</h2>
            <p class="text-on-primary/70 text-xl mb-12 font-light">{t('ctaDesc', lang)}</p>
            <div class="flex flex-wrap justify-center gap-6">
                <a href="/en/iletisim" class="bg-white text-primary px-10 py-5 rounded-xl font-semibold text-lg hover:shadow-2xl hover:shadow-white/20 hover:-translate-y-1 transition-all duration-300">
                    {t('heroCtaSecondary', lang)}
                </a>
            </div>
        </div>
    </section>
</Layout>
