---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/utils';
const lang = 'en' as const;
---

<Layout title="Home" lang={lang}>
    <!-- Hero Section -->
    <header class="relative pt-32 pb-20 px-8 md:px-12 overflow-hidden bg-surface bg-grid">
        <!-- Subtle gradients -->
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary-container/10 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
            <div class="lg:col-span-7 animate-fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/8 text-primary text-xs font-semibold mb-8 tracking-wider uppercase border border-primary/15">
                    <span class="material-symbols-outlined text-sm">verified</span>
                    {t('heroBadge', lang)}
                </div>
                <h1 class="display-lg text-5xl xl:text-7xl 2xl:text-8xl mb-8 text-on-background">
                    {t('heroTitle1', lang)} <br/>
                    <span class="gradient-text italic">{t('heroTitle2', lang)}</span>
                </h1>
                <p class="text-lg text-on-background/80 max-w-[520px] mb-12 font-body leading-relaxed font-light">
                    {t('heroDesc', lang)}
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="/en/hizmetler" class="bg-primary text-on-primary px-8 py-4 rounded-lg font-semibold text-base flex items-center gap-2 hover:bg-primary-container hover:shadow-lg hover:shadow-primary/20 transition-all duration-300 group">
                        {t('heroCtaPrimary', lang)}
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                    <a href="/en/iletisim" class="bg-surface-container-high text-on-background px-8 py-4 rounded-lg font-semibold text-base hover:bg-surface-variant hover:shadow-lg transition-all duration-300">
                        {t('heroCtaSecondary', lang)}
                    </a>
                </div>
            </div>
            <div class="lg:col-span-5 relative mt-12 lg:mt-0 z-20 animate-fade-right delay-2">
                <!-- Main Image Placeholder (Purged) -->
                <div class="w-full aspect-[4/5] md:aspect-square rounded-2xl overflow-hidden relative shadow-2xl border border-outline-variant/10 bg-surface-container-high flex flex-col items-center justify-center">
                    <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent pointer-events-none"></div>
                    <span class="material-symbols-outlined text-[120px] text-primary/20">query_stats</span>
                </div>
                
                <!-- Floating Stat Card -->
                <div class="absolute -bottom-6 -left-4 md:-left-12 bg-white/95 backdrop-blur-xl p-6 md:p-8 rounded-2xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.12)] border border-white max-w-[280px] card-hover animate-scale-in delay-4">
                    <div class="flex items-center gap-4 mb-3">
                        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-primary text-3xl">public</span>
                        </div>
                        <div class="text-primary text-5xl font-semibold font-headline tracking-tighter">{t('heroStat', lang)}</div>
                    </div>
                    <div class="text-on-surface font-semibold text-sm leading-snug">{t('heroStatLabel1', lang)}<br/>{t('heroStatLabel2', lang)}</div>
                </div>

                <!-- Secondary Floating Card -->
                <div class="absolute top-12 -right-4 md:-right-8 bg-surface-container/80 backdrop-blur-md py-4 px-6 rounded-2xl shadow-2xl border border-outline/20 flex items-center gap-4 card-hover animate-scale-in delay-5">
                    <div class="bg-accent/20 p-2.5 rounded-xl text-accent flex items-center justify-center">
                        <span class="material-symbols-outlined text-xl">workspace_premium</span>
                    </div>
                    <span class="text-on-background font-semibold text-sm tracking-wide">{t('heroExpBadge', lang)}</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Problem-Solution Section -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface">
        <div class="max-w-[1920px] mx-auto">
            <div class="mb-16 text-center">
                <h2 class="display-lg text-4xl md:text-5xl mb-4">{t('psSectionTitle', lang)}</h2>
                <p class="text-on-surface-variant max-w-2xl mx-auto font-light">{t('psSectionDesc', lang)}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Problem Card -->
                <div class="bg-surface-container-low p-10 md:p-12 rounded-2xl card-hover border border-outline-variant/30">
                    <div class="flex items-center gap-3 text-on-surface-variant mb-8">
                        <div class="w-10 h-10 rounded-xl bg-surface-variant flex items-center justify-center">
                            <span class="material-symbols-outlined text-outline">analytics</span>
                        </div>
                        <span class="font-semibold tracking-widest uppercase text-xs text-outline">{t('psProblems', lang)}</span>
                    </div>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <span class="text-on-surface-variant mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">{t('psP1Title', lang)}</h4>
                                <p class="text-on-surface-variant text-sm font-light">{t('psP1Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="text-on-surface-variant mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">{t('psP2Title', lang)}</h4>
                                <p class="text-on-surface-variant text-sm font-light">{t('psP2Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="text-on-surface-variant mt-1 material-symbols-outlined text-sm shrink-0">horizontal_rule</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1 text-on-surface">Inconsistent Reporting</h4>
                                <p class="text-on-surface-variant text-sm font-light">Weakened decision-making mechanisms due to manual processes and inconsistent data.</p>
                            </div>
                        </li>
                    </ul>
                </div>
                <!-- Solution Card -->
                <div class="bg-primary p-10 md:p-12 rounded-2xl text-white card-hover">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center">
                            <span class="material-symbols-outlined text-white">check_circle</span>
                        </div>
                        <span class="font-semibold tracking-widest uppercase text-xs text-white/80">{t('psSolutions', lang)}</span>
                    </div>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">{t('psS1Title', lang)}</h4>
                                <p class="text-white/70 text-sm">{t('psS1Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">{t('psS2Title', lang)}</h4>
                                <p class="text-white/70 text-sm">{t('psS2Desc', lang)}</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <span class="mt-1 material-symbols-outlined text-sm text-primary-container shrink-0">done_all</span>
                            <div>
                                <h4 class="font-semibold text-lg mb-1">Automated Compliance</h4>
                                <p class="text-white/70 text-sm">Full integration with e-Invoicing, e-Ledger, and regulatory requirements.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section (Bento Grid) -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface-container-lowest">
        <div class="max-w-[1920px] mx-auto">
            <div class="mb-12">
                <h2 class="display-lg text-4xl mb-3">{t('svcTitle', lang)}</h2>
                <p class="text-on-surface-variant font-light max-w-xl">We support your business's digital transformation journey with strategic solutions.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Main Service -->
                <div class="md:col-span-2 bg-surface-container-low p-10 rounded-2xl group hover:bg-primary hover:text-on-primary transition-all duration-500 flex flex-col justify-between h-[400px] card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-float">account_balance</span>
                        <h3 class="text-3xl font-semibold mb-4">{t('svcFiCoTitle', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-on-primary/80 max-w-md font-light">{t('svcFiCoDesc', lang)}</p>
                    </div>
                    <a class="inline-flex items-center gap-2 font-semibold group-hover:underline underline-offset-4 text-sm" href="/en/hizmetler">
                        {t('svcFiCoLink', lang)} <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_outward</span>
                    </a>
                </div>
                <!-- Localization Highlight -->
                <div class="bg-on-background p-10 rounded-2xl flex flex-col justify-between text-white card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl text-primary-container mb-6 group-hover:animate-icon-wiggle">flag</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcLocTitle', lang)}</h3>
                        <p class="text-on-surface-variant text-sm font-light">{t('svcLocDesc', lang)}</p>
                    </div>
                    <span class="bg-primary/20 text-primary-container self-start px-3 py-1 rounded-full text-xs font-semibold uppercase">{t('svcLocBadge', lang)}</span>
                </div>
                <!-- Global Projects -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-on-background hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-float">public</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcGlobalTitle', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-on-surface text-sm font-light">{t('svcGlobalDesc', lang)}</p>
                    </div>
                </div>
                <!-- Support & Outsourcing -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-on-background hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-wiggle">engineering</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcOutsourceTitle', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-on-surface text-sm font-light">{t('svcOutsourceDesc', lang)}</p>
                    </div>
                </div>
                <!-- S/4HANA -->
                <div class="bg-surface-container p-10 rounded-2xl flex flex-col justify-between group hover:bg-on-background hover:text-white transition-all duration-500 card-hover">
                    <div>
                        <span class="material-symbols-outlined text-4xl mb-6 group-hover:animate-icon-bounce">rocket_launch</span>
                        <h3 class="text-2xl font-semibold mb-4">{t('svcS4Title', lang)}</h3>
                        <p class="text-on-surface-variant group-hover:text-on-surface text-sm font-light">{t('svcS4Desc', lang)}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Harezm -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-on-background text-white relative overflow-hidden">
        <!-- Decorative -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[150px] pointer-events-none"></div>

        <div class="max-w-[1920px] mx-auto relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                <div>
                    <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">WHY US?</span>
                    <h2 class="display-lg text-4xl md:text-5xl mb-8">{t('whyTitle', lang)}</h2>
                    <p class="text-on-surface-variant text-lg mb-12 font-light">{t('whyDesc', lang)}</p>
                    <div class="grid grid-cols-1 gap-8">
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-float">psychology</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">{t('why1Title', lang)}</h4>
                                <p class="text-on-surface-variant font-light">{t('why1Desc', lang)}</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-wiggle">diversity_3</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">{t('why2Title', lang)}</h4>
                                <p class="text-on-surface-variant font-light">{t('why2Desc', lang)}</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6 group">
                            <div class="bg-primary/15 p-3.5 rounded-xl group-hover:bg-primary group-hover:scale-110 transition-all duration-300 shrink-0">
                                <span class="material-symbols-outlined text-primary group-hover:text-white group-hover:animate-icon-bounce">speed</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-xl mb-2">{t('why3Title', lang)}</h4>
                                <p class="text-on-surface-variant font-light">{t('why3Desc', lang)}</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="relative aspect-square md:aspect-[4/3] rounded-2xl border border-outline-variant/10 bg-surface-container flex flex-col items-center justify-center p-12">
                     <span class="material-symbols-outlined text-[100px] text-primary/10 absolute top-10 right-10">format_quote</span>
                     <p class="text-3xl md:text-4xl font-semibold italic leading-relaxed text-on-surface text-center">"Managing <br/>Complexity <br/>with Simplicity."</p>
                </div>
            </div>
        </div>
    </section>

    <!-- References Preview -->
    <section class="py-24 md:py-32 px-6 md:px-12 bg-surface">
        <div class="max-w-[1920px] mx-auto">
            <div class="text-center mb-16">
                <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">OUR REFERENCES</span>
                <h2 class="display-lg text-3xl md:text-4xl">{t('brandsTitle', lang)}</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4 lg:gap-5">
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Aselsan" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=aselsan.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Aselsan</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Pfizer" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=pfizer.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Pfizer</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="TSKB" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=tskb.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">TSKB</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="EVYAP" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=evyap.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Evyap</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Ferrero" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=ferrero.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Ferrero</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Temsa" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=temsa.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Temsa</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Borçelik" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=borcelik.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Borçelik</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Hayat Holding" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=hayat.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Hayat Holding</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Wavin" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=wavin.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Wavin</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="UCB Pharma" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=ucb.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">UCB Pharma</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Ülker" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=ulker.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Ülker</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Philip Morris" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=pmi.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Philip Morris</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Boyner" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=boyner.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Boyner</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Anadolu Efes" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=anadoluefes.com&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Anadolu Efes</span>
                </div>
                <div class="flex items-center gap-4 p-4 rounded-xl bg-white border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group grayscale hover:grayscale-0 card-hover">
                    <img alt="Sarkuysan" class="w-10 h-10 rounded-lg object-contain bg-white shadow-sm ring-1 ring-outline-variant/20" src="https://s2.googleusercontent.com/s2/favicons?domain=sarkuysan.com.tr&sz=128"/>
                    <span class="font-semibold text-sm text-on-surface group-hover:text-primary transition-colors truncate">Sarkuysan</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Thought Leadership (Premium Insight) -->
