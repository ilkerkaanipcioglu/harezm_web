---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="Insights | Harezm Technology" lang={lang}>
    <header class="relative pt-40 pb-24 md:pt-48 md:pb-32 bg-bg overflow-hidden border-b border-border-main">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-plum)_0%,_transparent_40%)] opacity-10 pointer-events-none"></div>

        <div class="max-w-container mx-auto px-8 md:px-12 relative z-10">
            <div class="w-full md:w-3/4 animate-fade-up">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface text-text-70 text-label mb-8 border border-border">
                    <span class="material-symbols-outlined text-sm">article</span>
                    OFFICIAL PUBLICATIONS
                </span>
                
                <h1 class="display-lg text-4xl md:text-h1 mb-6">
                    Insights <span class="bg-clip-text text-transparent bg-gradient-to-r from-teal to-plum">Series.</span>
                </h1>
                    We actively share our industry news, SAP world innovations, and AI product technical showcases through our official LinkedIn feeds.
                </p>
            </div>
        </div>
    </header>

    <section class="py-24 md:py-32 bg-bg2 relative">
        <div class="max-w-container mx-auto px-8 md:px-12">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Harezm Blog -->
                <a href="https://www.linkedin.com/company/2735651/posts/" target="_blank" rel="noopener noreferrer" class="glass-card rounded-3xl p-10 group hover:border-plum transition-all duration-300 block relative overflow-hidden h-full flex flex-col">
                    <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                        <svg class="w-32 h-32 text-plum fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </div>
                    <span class="inline-flex max-w-max items-center gap-2 px-3 py-1 bg-plum/10 text-plum text-xs font-bold uppercase tracking-widest rounded-full mb-6 relative z-10">CORPORATE FEED</span>
                    <h3 class="text-3xl font-headline font-bold text-on-background mb-4 relative z-10 group-hover:text-plum transition-colors max-w-[80%]">Harezm SAP Finance Blog</h3>
                    <p class="text-text-70 text-lg font-light leading-relaxed mb-10 relative z-10 max-w-sm flex-grow">Follow Harezm's SAP updates, transformation case studies, and corporate announcements.</p>
                    <div class="flex items-center gap-3 text-plum font-bold tracking-widest text-sm uppercase relative z-10 mt-auto">
                        Read on LinkedIn <span class="material-symbols-outlined transform group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
                    </div>
                </a>

                <!-- AgentAndBot Blog -->
                <a href="https://www.linkedin.com/showcase/agentandbot/posts/" target="_blank" rel="noopener noreferrer" class="glass-card rounded-3xl p-10 group hover:border-[#26A5E4] transition-all duration-300 block relative overflow-hidden h-full flex flex-col">
                    <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                         <svg class="w-32 h-32 text-[#26A5E4] fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </div>
                    <span class="inline-flex max-w-max items-center gap-2 px-3 py-1 bg-[#26A5E4]/10 text-[#26A5E4] text-xs font-bold uppercase tracking-widest rounded-full mb-6 relative z-10">AI SHOWCASE</span>
                    <h3 class="text-3xl font-headline font-bold text-on-background mb-4 relative z-10 group-hover:text-[#26A5E4] transition-colors max-w-[80%]">AgentAndBot News</h3>
                    <p class="text-text-70 text-lg font-light leading-relaxed mb-10 relative z-10 max-w-sm flex-grow">Explore our Artificial Intelligence (AI) solutions, Agent & Bot product updates, and technical showcases.</p>
                    <div class="flex items-center gap-3 text-[#26A5E4] font-bold tracking-widest text-sm uppercase relative z-10 mt-auto">
                        Read on LinkedIn <span class="material-symbols-outlined transform group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
                    </div>
                </a>
            </div>
        </div>
    </section>
</Layout>
