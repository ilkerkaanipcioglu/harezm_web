---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="SAP System Check-Up" lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6">SYSTEM ASSESSMENT</span>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">SAP System Check-Up</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed">Assess, optimize, and align your SAP landscape with best practices.</p>
            </div>
        </div>
    </section>

    <!-- Best Practice -->
    <section class="py-20 bg-surface">
        <div class="max-w-5xl mx-auto px-8">
            <h2 class="text-3xl font-bold font-headline mb-6">SAP Best Practice Alignment</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed mb-6">Digital transformation is no longer optional ” it is a key driver of long-term competitiveness. Organizations must continuously refine their systems to stay aligned with evolving technologies and industry standards.</p>
            <p class="text-lg text-on-surface-variant leading-relaxed">The SAP Check-Up service provides a comprehensive assessment of your current landscape, identifying how well your system aligns with SAP Best Practices. It highlights inefficiencies, risks, and opportunities for improvement.</p>
        </div>
    </section>

    <!-- System Health -->
    <section class="py-20 bg-on-background text-white">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-3xl font-bold font-headline mb-6">Measure System Health, Improve Performance</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">Over time, changing business requirements, regulatory updates, and custom developments can increase system complexity.</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    <div class="bg-white/5 border border-white/10 p-6 rounded-xl text-center">
                        <span class="material-symbols-outlined text-red-400 text-3xl mb-3">trending_down</span>
                        <p class="text-sm text-on-surface">Reduced performance</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-6 rounded-xl text-center">
                        <span class="material-symbols-outlined text-amber-400 text-3xl mb-3">hourglass_top</span>
                        <p class="text-sm text-on-surface">Inefficient processes</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-6 rounded-xl text-center">
                        <span class="material-symbols-outlined text-orange-400 text-3xl mb-3">payments</span>
                        <p class="text-sm text-on-surface">Increased costs</p>
                    </div>
                </div>
            </div>
            <div class="mt-12 bg-primary/20 border border-primary/30 rounded-xl p-8 text-center">
                <p class="text-primary-container font-medium">With a structured Check-Up approach, your system is evaluated objectively to create a more <strong>efficient, scalable, and maintainable</strong> architecture.</p>
            </div>
        </div>
    </section>

    <!-- Analysis Scope -->
    <section class="py-20 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold font-headline mb-4">In-Depth Analysis & Actionable Roadmap</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">architecture</span>
                    <h4 class="font-bold text-sm">SAP Architecture & Technical Assessment</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">checklist</span>
                    <h4 class="font-bold text-sm">Process Evaluation Across Modules</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">sync_alt</span>
                    <h4 class="font-bold text-sm">Integration & Data Flow Analysis</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">code</span>
                    <h4 class="font-bold text-sm">Custom Development Review</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">gavel</span>
                    <h4 class="font-bold text-sm">Compliance & Regulatory Checks</h4>
                </div>
            </div>
            <div class="mt-12 bg-primary-container p-8 rounded-xl text-center">
                <p class="text-on-primary-container font-medium">Based on these insights, a clear and <strong>prioritized action plan</strong> is delivered.</p>
            </div>
        </div>
    </section>

    <!-- Continuous Alignment -->
    <section class="py-20 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold font-headline mb-4">Continuous Alignment, Maximum Value</h2>
                <p class="text-on-surface-variant">The Check-Up is not just a snapshot ” it is a foundation for continuous improvement.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">update</span>
                    <h4 class="font-bold mb-2">Stay Current</h4>
                    <p class="text-on-surface-variant text-sm">Keep your systems up to date</p>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">bolt</span>
                    <h4 class="font-bold mb-2">Quick Adaptation</h4>
                    <p class="text-on-surface-variant text-sm">Adapt quickly to new business needs</p>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">tune</span>
                    <h4 class="font-bold mb-2">Controlled Development</h4>
                    <p class="text-on-surface-variant text-sm">Gain better control over developments</p>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">trending_up</span>
                    <h4 class="font-bold mb-2">Maximum ROI</h4>
                    <p class="text-on-surface-variant text-sm">Maximize return on your SAP investment</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
        <div class="max-w-5xl mx-auto px-8">
            <div class="bg-primary rounded-md p-12 text-center relative overflow-hidden">
                <h2 class="text-3xl font-bold font-headline text-white mb-4">Schedule Your SAP Check-Up</h2>
                <p class="text-white/70 mb-8">Let us analyze your SAP infrastructure and discover improvement opportunities together.</p>
                <div class="flex justify-center">
                    <a href="/en/contact" class="bg-white text-primary px-8 py-3 rounded-md font-bold hover:bg-surface-container-low transition-colors shadow-lg">Contact Us</a>
                </div>
            </div>
        </div>
    </section>
</Layout>
