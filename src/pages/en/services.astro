---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="Services" lang={lang}>
    <!-- HERO -->
    <section class="relative pt-40 pb-24 bg-plum overflow-hidden">
        <div class="max-w-7xl mx-auto px-8 relative z-10">
            <div class="w-full md:w-3/4">
                <span class="inline-block px-4 py-1.5 rounded-full bg-white/20 text-white border border-white/30 text-xs font-semibold tracking-widest mb-8 uppercase">
                    SAP EXPERTISE SERVICES
                </span>
                <h1 class="text-5xl md:text-7xl font-semibold font-headline text-white leading-tight tracking-tight mb-8">
                    Automating Your<br/><span class="text-white/80">Financial Systems.</span>
                </h1>
                <p class="text-lg md:text-xl text-white/90 max-w-2xl leading-relaxed mb-16">
                    We simplify your financial operations using AI and SAP architectures, securing your cross-border transformation strategies.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white/5 border border-white/10 p-8 rounded-md backdrop-blur-sm group transition-all">
                        <div class="text-4xl font-semibold text-white mb-2 font-headline">100+</div>
                        <div class="text-sm font-medium text-white/80 tracking-wider uppercase">Successful Projects</div>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-md backdrop-blur-sm group transition-all">
                        <div class="text-4xl font-semibold text-white mb-2 font-headline">15+</div>
                        <div class="text-sm font-medium text-white/80 tracking-wider uppercase">Years Experience</div>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-md backdrop-blur-sm group transition-all">
                        <div class="text-4xl font-semibold text-white mb-2 font-headline">24/7</div>
                        <div class="text-sm font-medium text-white/80 tracking-wider uppercase">Technical Support</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-white/10 to-transparent pointer-events-none"></div>
    </section>

    <!-- SERVICES BENTO GRID -->
    <section class="py-24 md:py-32 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="text-4xl font-semibold font-headline text-text-main mb-4">Our Strategic Focus Areas</h2>
                    <div class="h-1.5 w-24 bg-primary"></div>
                </div>
                <p class="text-text-70 max-w-md text-sm leading-relaxed">
                    We optimize high-volume financial processes and establish data-driven decision algorithms.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[280px]">
                <!-- Card 1: SAP FI & CO / Material Ledger (Merged) -->
                <div class="md:col-span-8 md:row-span-2 bg-primary p-10 rounded-md flex flex-col justify-between text-white relative overflow-hidden group">
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-4">
                            <span class="material-symbols-outlined text-5xl group-hover:animate-icon-float">account_balance</span>
                            <span class="px-3 py-1 bg-white/20 text-white rounded-full text-[10px] font-semibold tracking-tight">Harezm's Flagship</span>
                        </div>
                        <h3 class="text-3xl font-semibold font-headline mb-2">SAP FI, CO & Material Ledger</h3>
                        <p class="text-white/60 text-sm mb-5">We offer financial accounting, cost control, and actual costing within a unified structure.</p>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-3 text-white/80 text-xs">
                            <div>
                                <p class="text-white font-semibold text-[10px] tracking-widest uppercase mb-2">FI ” Financial Accounting</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>General Ledger (New GL)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Accounts Payable/Receivable (AP/AR)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Asset Accounting (AA)</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Bank Accounting</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Tax & e-Transformation</span></div>
                                </div>
                            </div>
                            <div>
                                <p class="text-white font-semibold text-[10px] tracking-widest uppercase mb-2">CO ” Controlling</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Cost Center Accounting</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Internal Orders</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Product Costing</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Profitability Analysis (CO-PA)</span></div>
                                </div>
                            </div>
                            <div>
                                <p class="text-white font-semibold text-[10px] tracking-widest uppercase mb-2">Material Ledger</p>
                                <div class="space-y-1.5">
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Actual Costing</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Multi-Currency Valuation</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Multi-Level Price Determination</span></div>
                                    <div class="flex items-center space-x-2"><span class="w-1 h-1 bg-primary-container rounded-full shrink-0"></span><span>Inventory Revaluation</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Card 5: S/4HANA -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between border border-outline-variant/20 group hover:bg-primary hover:text-white transition-all duration-500">
                    <div>
                        <span class="material-symbols-outlined text-text-main group-hover:text-white text-4xl mb-4 group-hover:animate-icon-bounce">rocket_launch</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">SAP S/4HANA Transformation</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed">Grow with SAP & Rise with SAP ” Flawless migration to next-gen ERP via Greenfield and Brownfield approaches.</p>
                    </div>
                    <a href="/en/s4hana" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Learn More <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 6: PS & BPC -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group">
                    <div>
                        <span class="material-symbols-outlined text-text-main text-4xl mb-4 group-hover:animate-icon-wiggle">schema</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main">SAP PS, IM &amp; BPC</h3>
                        <p class="text-text-70 text-sm leading-relaxed">We integrate your investment management, project planning, and budget consolidation processes using Project System, IM, and BPC.</p>
                    </div>
                </div>
                <!-- Card 7: AMS Support & Outsourcing -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between border border-outline-variant/20 group">
                    <div>
                        <span class="material-symbols-outlined text-primary text-4xl mb-4 group-hover:animate-icon-wiggle">engineering</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main">Outsourcing & Strategic AMS</h3>
                        <p class="text-text-70 text-sm leading-relaxed mb-4">We manage end-to-end, flexible, and high-quality SLAs utilizing our senior consultant team for your corporate SAP projects and continuous operations.</p>
                    </div>
                </div>
                <!-- Card 8: SAP RE-FX -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border-t-4 border-primary">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-float">real_estate_agent</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">SAP RE-FX Real Estate</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed">End-to-end solution for real estate portfolio management, leasing contracts, maintenance, and FI/CO integration.</p>
                    </div>
                    <a href="/en/sap-refx" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Learn More <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 9: SAP & OpenText -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border border-outline-variant/20">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-float">auto_awesome</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">SAP & OpenText</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed">Digital transformation with AI-backed document management, VIM invoice automation, and core SAP integration.</p>
                    </div>
                    <a href="/en/sap-opentext" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Learn More <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 10: SAP Check-Up -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border-t-4 border-primary">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-bounce">health_and_safety</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">System Optimization & Check-Up</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed">We identify hidden bottlenecks in your financial processes via SAP Best Practices benchmark analysis and draw out your automation roadmap.</p>
                    </div>
                    <a href="/en/sap-checkup" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Learn More <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 11: Danışmanlık -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container-low p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border border-outline-variant/20">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-wiggle">psychology</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">Consulting Services</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed">Advance into the future with IT strategy, digital transformation, AI consulting, and broad process optimization.</p>
                    </div>
                    <a href="/en/consulting" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Learn More <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 12: SAP Cash Management -->
                <div class="md:col-span-4 md:row-span-1 bg-surface-container p-8 rounded-md flex flex-col justify-between group hover:bg-primary hover:text-white transition-all duration-500 border-t-4 border-primary">
                    <div>
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-4xl mb-4 group-hover:animate-icon-float">account_balance_wallet</span>
                        <h3 class="text-xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">SAP Cash Management</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed">Increase cash visibility to 100%, and instantly manage your bank accounts and liquidity forecasts from a single center.</p>
                    </div>
                    <a href="/en/sap-cash-management" class="inline-flex items-center gap-2 font-semibold text-sm text-primary group-hover:text-white mt-4 hover:underline underline-offset-4">Learn More <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                </div>
                <!-- Card 13: SAP TRM -->
                <div class="md:col-span-12 md:row-span-1 bg-surface-container-highest p-10 rounded-2xl flex flex-col md:flex-row justify-between items-center group hover:bg-primary hover:text-white transition-all duration-500 border border-outline-variant/20 relative overflow-hidden">
                    <div class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-primary/10 to-transparent pointer-events-none"></div>
                    <div class="md:w-2/3 relative z-10">
                        <span class="material-symbols-outlined text-primary group-hover:text-white text-5xl mb-4 group-hover:animate-icon-wiggle">monitoring</span>
                        <h3 class="text-2xl font-semibold font-headline mb-3 text-text-main group-hover:text-white">SAP Treasury and Risk Management</h3>
                        <p class="text-text-70 group-hover:text-white/80 text-sm leading-relaxed md:pr-12">Optimize Working Capital and achieve a 30% increase in cash efficiency. Manage your liquidity, payments, and risks centrally over a unified financial data fabric.</p>
                    </div>
                    <div class="md:w-1/3 flex md:justify-end mt-8 md:mt-0 relative z-10">
                        <a href="/en/sap-trm" class="inline-flex items-center gap-2 font-semibold text-sm bg-primary text-white group-hover:bg-white group-hover:text-primary px-8 py-4 rounded-xl hover:shadow-xl hover:-translate-y-1 transition-all duration-300">Evaluate Instantly <span class="material-symbols-outlined text-sm">arrow_outward</span></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA SECTION -->
    <section class="py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-8">
            <div class="bg-primary rounded-md p-12 md:p-20 text-center relative overflow-hidden">
                <h2 class="text-3xl md:text-5xl font-semibold font-headline text-white mb-8 relative z-10">Let's Build Your Strategy Together</h2>
                <p class="text-white/80 max-w-2xl mx-auto mb-12 text-lg relative z-10">Evaluating your company's financial bottlenecks with a detailed analysis, we construct a solid automation roadmap for your finance targets.</p>
                <div class="flex flex-col md:flex-row gap-6 justify-center relative z-10">
                    <a href="/en/contact" class="bg-white text-primary px-10 py-4 rounded-md font-semibold text-sm hover:shadow-2xl hover:-translate-y-1 transition-all shadow-xl">
                        Start Assessment
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
