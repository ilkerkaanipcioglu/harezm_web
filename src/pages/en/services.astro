---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

const lang = 'en' as const;
---

<Layout title="Services | Harezm" lang={lang}>
    <!-- HERO -->
    <header class="relative pt-40 pb-24 md:pt-48 md:pb-32 bg-bg overflow-hidden border-b border-border-main">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-primary)_0%,_transparent_40%)] opacity-10 pointer-events-none"></div>
        <div class="absolute w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none -right-10 -bottom-10"></div>

        <div class="max-w-container mx-auto px-8 md:px-12 relative z-10">
            <div class="w-full md:w-3/4 animate-fade-up">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface text-text-70 text-label mb-8 border border-border">
                    <Icon name="icon_06_star" size={14} animate />
                    CORPORATE SERVICES
                </span>
                
                <h1 class="display-lg text-4xl md:text-h1 mb-6">
                    Automating Your<br/><span class="bg-clip-text text-transparent bg-gradient-to-r from-teal to-primary">Financial Systems.</span>
                </h1>
                <p class="text-text-70 text-body-lg max-w-2xl font-light leading-relaxed mb-10">
                    Sustaining your cross-border transformation strategy by simplifying financial operations with AI and SAP architecture.
                </p>
                
                <div class="flex flex-wrap gap-4">
                    <a href="#sap-platform" class="bg-primary text-white px-8 py-4 rounded-lg font-medium text-ui hover:bg-primary-hover transition-colors shadow-lg">Our Solutions</a>
                    <a href="/en/contact" class="bg-white text-text-main border border-border px-8 py-4 rounded-lg font-medium text-ui hover:bg-bg transition-colors">Request Catalog</a>
                </div>
            </div>
        </div>
    </header>

    <!-- CONTENT -->
    <section id="sap-platform" class="py-24 md:py-32 bg-bg relative">
        <div class="max-w-container mx-auto px-8 md:px-12">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="display-lg text-3xl md:text-h2 mb-4">Strategic Focus Areas</h2>
                    <div class="h-1.5 w-24 bg-primary"></div>
                </div>
                <p class="text-text-70 max-w-md text-sm font-light leading-relaxed">
                    Optimizing high-volume financial processes and establishing data-driven decision algorithms.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">

                <!-- Category 1 Title -->
                <div class="md:col-span-12 mt-4 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-serif text-teal flex items-center gap-3">
                        <Icon name="icon_05_settings" size={24} animate />
                        1. SAP Platform
                    </h3>
                </div>

                <!-- Main Card: SAP FI/CO -->
                <div class="md:col-span-12 glass-card bg-plum p-10 md:p-14 rounded-3xl group relative overflow-hidden text-white border-plum/20">
                    <div class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-white/10 to-transparent pointer-events-none"></div>
                    <div class="relative z-10 w-full">
                        <div class="flex justify-between items-start mb-6">
                            <Icon name="icon_14_api" size={48} class="opacity-80 group-hover:opacity-100 transition-opacity" />
                            <span class="px-3 py-1 bg-white/20 text-white rounded-full text-[10px] font-bold tracking-[0.1em] uppercase">Flagship Solution</span>
                        </div>
                        <h3 class="text-3xl font-serif mb-3">SAP FI, CO & Material Ledger</h3>
                        <p class="text-white/80 text-sm mb-8 font-light max-w-lg">We offer financial accounting, cost control, and actual costing calculation in a single architectural structure.</p>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-6 text-white/90 text-sm font-light">
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">FI — Financial Accounting</p>
                                <ul class="space-y-2 text-white/70">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>General Ledger (New GL)</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>AP / AR</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Asset Management</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Bank Accounting</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Tax & e-Transformation</li>
                                </ul>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">CO — Controlling</p>
                                <ul class="space-y-2 text-white/70">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Cost Center</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Internal Order</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Product Costing</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Profitability Analysis (CO-PA)</li>
                                </ul>
                            </div>
                            <div>
                                <p class="text-white font-bold text-[10px] tracking-widest uppercase mb-3">Material Ledger</p>
                                <ul class="space-y-2 text-white/70">
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Actual Costing</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Multi-Currency Valuation</li>
                                    <li class="flex items-center gap-2"><div class="w-1 h-1 bg-teal rounded-full"></div>Inventory Revaluation</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card: SAP S/4HANA -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_12_sun" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP S/4HANA Transformation</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Grow with SAP & Rise with SAP — seamless transition to the world of next-generation ERP with Greenfield and Brownfield approaches.</p>
                    </div>
                    <a href="/en/contact" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Card: SAP PS, IM -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_05_settings" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP PS, IM & BPC</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">We integrate your investment management, project planning, and budget consolidation processes into a single module.</p>
                    </div>
                </div>

                <!-- Card: SAP RE-FX -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_01_home" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP RE-FX Real Estate</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">End-to-end solution with real estate portfolio management, lease contracts, maintenance/repairs, and FI/CO integration.</p>
                    </div>
                    <a href="/en/sap-refx" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Card: SAP Cash Management -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_18_lock" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP Cash Management</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Achieve 100% cash visibility; manage your bank accounts and liquidity forecasts in real-time.</p>
                    </div>
                    <a href="/en/sap-cash-management" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Featured Card: SAP TRM -->
                <div class="md:col-span-12 md:row-span-1 glass-card p-10 md:p-12 rounded-2xl flex flex-col md:flex-row justify-between items-center group hover:border-primary transition-all duration-300 border-l-4 border-l-transparent hover:border-l-plum">
                    <div class="md:w-2/3 relative z-10">
                        <div class="w-16 h-16 rounded-xl flex items-center justify-center bg-bg border border-border mb-8 group-hover:border-primary transition-colors">
                            <Icon name="icon_05_settings" size={32} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-3xl font-serif mb-4 text-text-main group-hover:text-primary transition-colors">SAP Treasury and Risk Management</h3>
                        <p class="text-text-70 font-light leading-relaxed md:pr-12">Optimize Working Capital, increase cash efficiency by 30%. Manage your liquidity, payments, and risks centrally on the financial data fabric.</p>
                    </div>
                    <div class="md:w-1/3 flex md:justify-end mt-8 md:mt-0 relative z-10">
                        <a href="/en/sap-trm" class="inline-flex items-center gap-2 font-medium text-sm bg-bg border border-border text-text-main hover:bg-primary hover:text-white px-8 py-4 rounded-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 whitespace-nowrap">Examine Now <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                    </div>
                </div>

                <!-- Card: SAP Asset Accounting -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_05_settings" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP Asset Accounting (AA)</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Value your company's largest assets with millimetric precision and automate your depreciation plans.</p>
                    </div>
                    <a href="/en/sap-aa" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Card: SAP Financial Consolidation -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_05_settings" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP Financial Consolidation</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Measure the profitability of your holding and group companies at a glance with real figures; reduce the process from months to days.</p>
                    </div>
                    <a href="/en/sap-finansal-konsolidasyon" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Category 2 Title -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-serif text-teal flex items-center gap-3">
                        <Icon name="icon_14_api" size={24} animate />
                        2. Integration & Custom Solutions
                    </h3>
                </div>

                <!-- Card: OpenText -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_12_sun" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP & OpenText</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Digital transformation with AI-powered document management, VIM invoice automation, and SAP integration.</p>
                    </div>
                    <a href="/en/sap-opentext" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Card: KDV Iade -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_05_settings" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">VAT Refund System</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Create your VAT refund lists via SAP with a single click, 100% compatible with official formats in Turkey.</p>
                    </div>
                    <a href="/en/kdv-iade-paketi" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Card: e-Ticaret -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_01_home" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">e-Commerce Integration</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Flow order, inventory, shipping, and invoice data in real-time from sales channels into your SAP infrastructure.</p>
                    </div>
                    <a href="/en/e-ticaret" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>
                

                <!-- Category 3 Title -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-serif text-teal flex items-center gap-3">
                        <Icon name="icon_18_lock" size={24} animate />
                        3. Managed Services & E-State
                    </h3>
                </div>

                <!-- Card: Online DBS -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_18_lock" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">Online DBS & Bank Integration</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Automate your bank reconciliations and DBS collections, reflecting them instantly into your ERP system.</p>
                    </div>
                    <a href="/en/online-dbs" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Card: TMS 29 -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_18_lock" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">Inflation Accounting</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Remove the calculation burden from SAP while meeting legal requirements in high-inflationary environments.</p>
                    </div>
                    <a href="/en/enflasyon-muhasebesi" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                <!-- Category 4 Title -->
                <div class="md:col-span-12 mt-12 mb-2 border-b border-border-main pb-4">
                    <h3 class="text-2xl font-serif text-teal flex items-center gap-3">
                        <Icon name="icon_08_chat" size={24} animate />
                        4. Future Tech & Academy
                    </h3>
                </div>

                <!-- Featured Card: SAP Joule -->
                <div class="md:col-span-8 md:row-span-1 glass-card p-10 md:p-12 rounded-2xl flex flex-col md:flex-row justify-between items-center group hover:border-primary transition-all duration-300 border-l-4 border-l-transparent hover:border-l-primary">
                    <div class="md:w-2/3 relative z-10">
                        <div class="w-16 h-16 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_08_chat" size={32} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-2xl font-serif mb-3 text-text-main group-hover:text-primary transition-colors">SAP Joule and AI Agents</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Command your company's ERP memory with AI agents and transform process efficiency.</p>
                    </div>
                    <div class="md:w-1/3 flex md:justify-end mt-8 md:mt-0 relative z-10">
                        <a href="/en/sap-trm" class="inline-flex items-center gap-2 font-medium text-sm bg-bg border border-border text-text-main hover:bg-primary hover:text-white px-8 py-4 rounded-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 whitespace-nowrap">Examine Now <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                    </div>
                </div>

                <!-- Card: SAP Training -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_08_chat" size={24} class="text-text-main group-hover:text-primary transition-colors" />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">SAP Training Center</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Bring your internal competencies to the top with our modular and visionary SAP trainings.</p>
                    </div>
                    <a href="/en/sap-egitimleri" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

<!-- Card 10: SAP Check-Up -->
<div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_24_check_done" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">System Optimization & Check-Up</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">We identify hidden bottlenecks in your financial processes with SAP Best Practice compliance analysis and map your journey.</p>
                    </div>
                    <a href="/en/sap-checkup" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                
                <!-- Card: Danışmanlık -->
                <div class="md:col-span-4 md:row-span-1 glass-card p-8 rounded-2xl flex flex-col justify-between group hover:border-primary transition-all duration-300">
                    <div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-bg border border-border mb-6 group-hover:border-primary transition-colors">
                            <Icon name="icon_08_chat" size={24} class="text-text-main group-hover:text-primary transition-colors" animate />
                        </div>
                        <h3 class="text-xl font-medium mb-3 text-text-main group-hover:text-primary transition-colors">Consulting Services</h3>
                        <p class="text-text-70 text-sm font-light leading-relaxed mb-6">Carry your business into the future with IT strategy, digital transformation, AI consulting, and process optimization.</p>
                    </div>
                    <a href="/en/consulting" class="inline-flex items-center gap-2 font-medium text-sm text-text-main group-hover:text-primary transition-colors">View Details <Icon name="icon_17_share" size={12} class="rotate-[-45deg]" /></a>
                </div>

                
            </div>
        </div>
    </section>

    <!-- CALL TO ACTION -->
    <section class="py-24 md:py-32 bg-bg text-center">
        <div class="max-w-3xl mx-auto">
            <Icon name="icon_17_share" size={48} class="text-border mb-6" />
            <h2 class="display-lg text-3xl md:text-h2 mb-6">Let's Build Your Strategy Together</h2>
            <p class="text-text-70 font-light mb-10 max-w-2xl mx-auto text-lg">Let's evaluate your business's financial bottlenecks with a detailed analysis and realize your automation goals with the right plan.</p>
            
