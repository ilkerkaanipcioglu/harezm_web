---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const lang = 'en' as const;
---
<Layout title="SAP & OpenText Consulting | Harezm" description="Enterprise Information Management (EIM) and VIM solutions with SAP and OpenText integration for automated workflows." lang={lang}>
    <!-- Hero -->
    <section class="relative pt-32 pb-20 px-8 md:px-12 flex flex-col items-center bg-bg border-b border-border-main overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_var(--color-primary)_0%,_transparent_50%)] opacity-10 pointer-events-none"></div>
        <div class="max-w-container mx-auto">
            <div class="text-center max-w-4xl mx-auto animate-fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface text-text-70 text-label mb-8 border border-border">
                     <Icon name="icon_05_settings" size={14} class="text-teal" />
                     SAP & OPENTEXT
                </div>
                <h1 class="display-lg text-4xl md:text-5xl lg:text-h1 mb-6 text-text-main">SAP & OpenText Consulting Services</h1>
                <p class="text-text-70 text-body-lg mb-10 font-light max-w-2xl mx-auto">End-to-end solutions designed to streamline operations and maximize business performance.</p>
            </div>
        </div>
    </section>

    <!-- Digital Transformation -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-bg2 relative overflow-hidden border-b border-border-main">
        <div class="max-w-container mx-auto text-center md:text-left">
            <span class="text-label text-teal uppercase mb-4 block">TRANSFORMATION</span>
            <h2 class="display-lg text-3xl md:text-4xl mb-6 text-text-main">Driving Digital Transformation</h2>
            <p class="text-text-70 text-body-lg font-light mb-6">Modern enterprises require more than just working systems — they need intelligent, connected, and scalable platforms. By combining SAP and OpenText technologies, we unify your financial processes, document management, and operational workflows into a seamless ecosystem.</p>
            <p class="text-text-70 text-body-lg font-light">Our consultants approach each project with a structured methodology, covering analysis, design, implementation, and optimization. Instead of generic solutions, we build flexible architectures tailored to your organization's unique needs.</p>
        </div>
    </section>

    <!-- AI-Powered -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-bg relative overflow-hidden border-b border-border-main">
        <div class="max-w-container mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <span class="inline-block px-3 py-1 rounded-full bg-bg text-text-main border border-border text-label mb-4 hover:border-primary/30 transition-colors">NEXT-GEN</span>
                    <h2 class="display-lg text-3xl md:text-h2 mb-6">AI-Powered Business Processes</h2>
                    <p class="text-text-70 leading-relaxed font-light text-body-lg mb-8">We enhance traditional ERP and content management systems with artificial intelligence capabilities to extract value from unstructured data.</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="glass-card p-8 rounded-2xl group flex flex-col justify-between">
                        <div class="w-12 h-12 rounded-xl border border-border flex items-center justify-center mb-6 bg-bg group-hover:border-teal/30 transition-colors">
                            <Icon name="icon_22_menu" size={24} class="text-teal" />
                        </div>
                        <h4 class="text-h4 mb-2 text-text-main group-hover:text-primary transition-colors">Auto Classification</h4>
                        <p class="text-text-70 text-sm font-light">Automated document classification</p>
                    </div>
                    <div class="glass-card p-8 rounded-2xl group flex flex-col justify-between">
                        <div class="w-12 h-12 rounded-xl border border-border flex items-center justify-center mb-6 bg-bg group-hover:border-teal/30 transition-colors">
                            <Icon name="icon_02_search" size={24} class="text-teal" />
                        </div>
                        <h4 class="text-h4 mb-2 text-text-main group-hover:text-primary transition-colors">Data Extraction</h4>
                        <p class="text-text-70 text-sm font-light">Intelligent extraction and validation</p>
                    </div>
                    <div class="glass-card p-8 rounded-2xl group flex flex-col justify-between">
                        <div class="w-12 h-12 rounded-xl border border-border flex items-center justify-center mb-6 bg-bg group-hover:border-teal/30 transition-colors">
                            <Icon name="icon_18_lock" size={24} class="text-teal" />
                        </div>
                        <h4 class="text-h4 mb-2 text-text-main group-hover:text-primary transition-colors">Exception Detection</h4>
                        <p class="text-text-70 text-sm font-light">Risk prevention and anomalies</p>
                    </div>
                    <div class="glass-card p-8 rounded-2xl group flex flex-col justify-between">
                        <div class="w-12 h-12 rounded-xl border border-border flex items-center justify-center mb-6 bg-bg group-hover:border-teal/30 transition-colors">
                            <Icon name="icon_12_star" size={24} class="text-teal" />
                        </div>
                        <h4 class="text-h4 mb-2 text-text-main group-hover:text-primary transition-colors">Smart Insights</h4>
                        <p class="text-text-70 text-sm font-light">Process optimization recommendations</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- VIM -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-bg2 relative box-border border-b border-border-main">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-primary/10 rounded-full blur-[100px]"></div>
        <div class="max-w-container mx-auto relative z-10 text-center">
            <Icon name="icon_23_large_language_model" size={60} class="text-primary mx-auto mb-8" animate={true} />
            <h2 class="display-lg text-4xl mb-4 text-text-main">Vendor Invoice Management (VIM)</h2>
            <p class="text-text-70 mb-16 max-w-2xl mx-auto font-light text-body-lg">Managing supplier invoices efficiently is critical for financial accuracy and compliance. We architect the most advanced VIM landscapes in the industry.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="glass-card p-8 rounded-2xl text-center group hover:border-teal/30 transition-all">
                    <Icon name="icon_07_send" size={32} class="text-teal mb-4 mx-auto" />
                    <h4 class="text-sm font-medium uppercase tracking-widest text-text-main mb-2">Automation</h4>
                    <p class="text-text-70 text-sm font-light leading-relaxed">Invoice processing becomes autonomous.</p>
                </div>
                <div class="glass-card p-8 rounded-2xl text-center group hover:border-teal/30 transition-all">
                    <Icon name="icon_11_clock" size={32} class="text-teal mb-4 mx-auto" />
                    <h4 class="text-sm font-medium uppercase tracking-widest text-text-main mb-2">Speed</h4>
                    <p class="text-text-70 text-sm font-light leading-relaxed">Approval cycles are significantly accelerated.</p>
                </div>
                <div class="glass-card p-8 rounded-2xl text-center group hover:border-teal/30 transition-all">
                    <Icon name="icon_17_share" size={32} class="text-teal mb-4 mx-auto" />
                    <h4 class="text-sm font-medium uppercase tracking-widest text-text-main mb-2">Full Integration</h4>
                    <p class="text-text-70 text-sm font-light leading-relaxed">Seamless and native SAP FI matching.</p>
                </div>
                <div class="glass-card p-8 rounded-2xl text-center group hover:border-teal/30 transition-all">
                    <Icon name="icon_02_search" size={32} class="text-teal mb-4 mx-auto" />
                    <h4 class="text-sm font-medium uppercase tracking-widest text-text-main mb-2">Transparency</h4>
                    <p class="text-text-70 text-sm font-light leading-relaxed">Full auditability and localized traceability.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Support Services -->
    <section class="py-24 md:py-32 px-8. md:px-12 bg-bg relative box-border border-b border-border-main">
        <div class="max-w-container mx-auto">
            <div class="text-center mb-20">
                <h2 class="display-lg text-4xl mb-4 text-text-main">SAP & OpenText Support Services</h2>
                <p class="text-text-70 text-body-lg font-light">Ensuring continuity, stability, and continuous improvement of your systems.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="glass-card p-10 rounded-2xl group flex flex-col items-start border-t border-border hover:border-primary transition-all">
                    <div class="w-16 h-16 rounded-xl border border-border flex items-center justify-center mb-8 bg-bg group-hover:border-teal/30">
                        <Icon name="icon_04_user" size={32} class="text-teal" animate={true} />
                    </div>
                    <h3 class="text-h4 mb-4 text-text-main group-hover:text-primary transition-colors">Reliable Operations</h3>
                    <ul class="space-y-4 text-text-70 text-sm font-light">
                        <li class="flex items-start gap-2"><Icon name="icon_24_check_done" size={16} class="text-primary mt-1" /> End-user support</li>
                        <li class="flex items-start gap-2"><Icon name="icon_24_check_done" size={16} class="text-primary mt-1" /> Issue resolution</li>
                        <li class="flex items-start gap-2"><Icon name="icon_24_check_done" size={16} class="text-primary mt-1" /> Process enhancements</li>
                    </ul>
                </div>
                <div class="glass-card p-10 rounded-2xl group flex flex-col items-start border-t border-border hover:border-primary transition-all">
                    <div class="w-16 h-16 rounded-xl border border-border flex items-center justify-center mb-8 bg-bg group-hover:border-teal/30">
                        <Icon name="icon_22_menu" size={32} class="text-teal" animate={true} />
                    </div>
                    <h3 class="text-h4 mb-4 text-text-main group-hover:text-primary transition-colors">Continuous Adaptation</h3>
                    <p class="text-text-70 text-sm font-light leading-relaxed">As your organization evolves, your systems must evolve with it. We assist with onboarding new users and adapting to organizational changes.</p>
                </div>
                <div class="glass-card p-10 rounded-2xl group flex flex-col items-start border-t border-border hover:border-primary transition-all">
                    <div class="w-16 h-16 rounded-xl border border-border flex items-center justify-center mb-8 bg-bg group-hover:border-teal/30">
                        <Icon name="icon_27_chart" size={32} class="text-teal" animate={true} />
                    </div>
                    <h3 class="text-h4 mb-4 text-text-main group-hover:text-primary transition-colors">Proactive Monitoring</h3>
                    <p class="text-text-70 text-sm font-light leading-relaxed">Our approach goes beyond reactive support. We monitor system performance, identify potential risks early, and take preventive actions.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 md:py-48 px-8 md:px-12 bg-primary relative overflow-hidden text-center flex flex-col justify-center items-center">
        <!-- Radial gradient background overlay -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--color-primary-hover)_0%,_transparent_70%)] opacity-50"></div>
        
        <div class="max-w-container mx-auto relative z-10 flex flex-col items-center">
             <h2 class="display-lg text-4xl md:text-h1 mb-6 text-white">Accelerate Your Transformation</h2>
             <p class="text-white/80 text-xl md:text-2xl mb-12 font-light max-w-[600px]">
                 Future-proof your business processes with SAP and OpenText integration.
             </p>
            
            <a href="/en/contact" class="bg-bg text-text-main px-10 py-5 rounded-lg font-medium text-lg hover:bg-bg2 transition-colors inline-flex items-center gap-2 mb-16 border border-border group">
                Contact Us Today
                <Icon name="icon_17_share" size={20} class="rotate-[-45deg] group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
            </a>
        </div>
    </section>
</Layout>
