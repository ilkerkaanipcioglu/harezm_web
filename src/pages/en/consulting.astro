---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="Consulting Services" lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6">STRATEGIC CONSULTING</span>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">Consulting Services</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed">Align your business with the demands of the digital era through strategic and technology-driven solutions.</p>
            </div>
        </div>
    </section>

    <!-- Rethink -->
    <section class="py-20 bg-surface">
        <div class="max-w-5xl mx-auto px-8">
            <h2 class="text-3xl font-bold font-headline mb-6">Rethink Your Business, Continuously Optimize</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed mb-6">In a rapidly evolving economy, maintaining the status quo is not enough. Organizations must become agile, data-driven, and continuously evolving to stay competitive.</p>
            <p class="text-lg text-on-surface-variant leading-relaxed">Our consulting approach focuses on creating strong alignment between your business objectives and your technology landscape. We assess your current state, identify inefficiencies, and define clear, actionable roadmaps for measurable improvement.</p>
        </div>
    </section>

    <!-- Strategy to Execution -->
    <section class="py-20 bg-on-background text-white">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-3xl font-bold font-headline mb-6">From Strategy to Execution</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8">We go beyond recommendations by actively supporting implementation. This ensures your organization becomes:</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    <div class="bg-white/5 border border-white/10 p-8 rounded-xl text-center hover:border-primary-container/50 transition-all">
                        <span class="material-symbols-outlined text-primary-container text-3xl mb-3">speed</span>
                        <p class="text-sm font-bold text-white">Faster in decision-making</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-xl text-center hover:border-primary-container/50 transition-all">
                        <span class="material-symbols-outlined text-primary-container text-3xl mb-3">sync_alt</span>
                        <p class="text-sm font-bold text-white">Adaptable to change</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-xl text-center hover:border-primary-container/50 transition-all">
                        <span class="material-symbols-outlined text-primary-container text-3xl mb-3">expand</span>
                        <p class="text-sm font-bold text-white">Scalable & future-ready</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- AI-Enhanced -->
    <section class="py-20 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-4">AI-POWERED</span>
                    <h2 class="text-3xl font-bold font-headline mb-6">AI-Enhanced Consulting</h2>
                    <p class="text-on-surface-variant leading-relaxed">We extend traditional consulting with artificial intelligence capabilities. This allows you to plan not only for today, but for the future.</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20 hover:border-primary/50 transition-all">
                        <span class="material-symbols-outlined text-primary text-3xl mb-3">insights</span>
                        <h4 class="font-bold text-sm mb-1">Decision Support</h4>
                        <p class="text-on-surface-variant text-xs">Data-driven decision support</p>
                    </div>
                    <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20 hover:border-primary/50 transition-all">
                        <span class="material-symbols-outlined text-primary text-3xl mb-3">lightbulb</span>
                        <h4 class="font-bold text-sm mb-1">Smart Insights</h4>
                        <p class="text-on-surface-variant text-xs">Intelligent process improvement</p>
                    </div>
                    <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20 hover:border-primary/50 transition-all">
                        <span class="material-symbols-outlined text-primary text-3xl mb-3">analytics</span>
                        <h4 class="font-bold text-sm mb-1">Efficiency Analysis</h4>
                        <p class="text-on-surface-variant text-xs">Operational efficiency analysis</p>
                    </div>
                    <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/20 hover:border-primary/50 transition-all">
                        <span class="material-symbols-outlined text-primary text-3xl mb-3">smart_toy</span>
                        <h4 class="font-bold text-sm mb-1">Automation</h4>
                        <p class="text-on-surface-variant text-xs">Identifying automation opportunities</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Scope -->
    <section class="py-20 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold font-headline mb-4">Scope of Services</h2>
                <p class="text-on-surface-variant">Our consulting services include:</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">computer</span>
                    <h4 class="font-bold text-sm">IT Strategy</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">transform</span>
                    <h4 class="font-bold text-sm">Digital Transformation</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">map</span>
                    <h4 class="font-bold text-sm">Migration Strategy & Roadmap</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">tune</span>
                    <h4 class="font-bold text-sm">Process Assessment & Optimization</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">settings_suggest</span>
                    <h4 class="font-bold text-sm">Managed Services Strategy</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">change_circle</span>
                    <h4 class="font-bold text-sm">Change & Adoption Management</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 hover:shadow-lg hover:border-primary/40 transition-all text-center col-span-1 md:col-span-2">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">psychology</span>
                    <h4 class="font-bold text-sm">AI Consulting Services</h4>
                </div>
            </div>
        </div>
    </section>

    <!-- Thought Leadership (Premium Insight) -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-surface-container-lowest border-t border-outline-variant/10">
        <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
                <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">THOUGHT LEADERSHIP</span>
                <h2 class="display-lg text-4xl md:text-5xl mb-6">CFO's Transformation Agenda</h2>
                <p class="text-on-surface-variant text-lg leading-relaxed font-light mb-8 max-w-xl">
                    Discover how best-in-class financial operations are built, artificial intelligence integrations, and the architecture of time savings up to 40% in our special publication.
                </p>
                <a href="/harezm_cfo_ajandasi.pdf" target="_blank" class="inline-flex items-center gap-3 bg-on-background text-white px-8 py-4 rounded-lg font-semibold text-sm hover:shadow-2xl hover:-translate-y-1 transition-all">
                    View / Download Report
                    <span class="material-symbols-outlined text-base">download</span>
                </a>
            </div>
            <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent blur-3xl -z-10"></div>
                <div class="aspect-[4/3] rounded-2xl bg-surface-container-low border border-outline-variant/20 shadow-[-10px_20px_40px_rgba(0,0,0,0.05)] p-12 flex flex-col justify-between group">
                    <div>
                        <span class="material-symbols-outlined text-4xl text-primary mb-6">menu_book</span>
                        <h3 class="display-lg text-2xl md:text-3xl mb-4 group-hover:text-primary transition-colors">AI-Supported Finance: Cross-Border Operations</h3>
                        <p class="text-on-surface-variant font-light text-sm">SAP FI Transformation in 3 Months and End-to-End Cost Saving Case Studies.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
        <div class="max-w-5xl mx-auto px-8">
            <div class="bg-primary rounded-md p-12 text-center relative overflow-hidden">
                <h2 class="text-3xl font-bold font-headline text-white mb-4">Future-Proof Your Business</h2>
                <p class="text-white/70 mb-8">Accelerate your digital transformation with strategic consulting.</p>
                <div class="flex justify-center">
                    <a href="/en/contact" class="bg-white text-primary px-8 py-3 rounded-md font-bold hover:bg-surface-container-low transition-colors shadow-lg">Contact Us</a>
                </div>
            </div>
        </div>
    </section>
</Layout>
