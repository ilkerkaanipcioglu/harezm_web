---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const lang = 'en' as const;
---
<Layout title="Strategic Consulting Services" lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6 border border-primary/20">
                     <Icon name="icon_05_settings" size={14} class="opacity-70" />
                     STRATEGIC CONSULTING
                </div>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">Consulting Services</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed max-w-2xl mx-auto">Align your business with the demands of the digital era through strategic and technology-driven solutions.</p>
            </div>
        </div>
    </section>

    <!-- Rethink -->
    <section class="py-20 bg-surface">
        <div class="max-w-5xl mx-auto px-8 text-center md:text-left">
            <h2 class="text-3xl font-bold font-headline mb-6">Rethink Your Business, Continuously Optimize</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed mb-6">In a rapidly evolving economy, maintaining the status quo is not enough. Organizations must become agile, data-driven, and continuously evolving to stay competitive.</p>
            <p class="text-lg text-on-surface-variant leading-relaxed font-light">Our consulting approach focuses on creating strong alignment between your business objectives and your technology landscape. We assess your current state, identify inefficiencies, and define clear, actionable roadmaps for measurable improvement.</p>
        </div>
    </section>

    <!-- Strategy to Execution -->
    <section class="py-24 bg-on-background text-white">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-4xl font-bold font-headline mb-6">From Strategy to Execution</h2>
                    <p class="text-on-surface-variant leading-relaxed mb-8 opacity-80">We go beyond recommendations by actively supporting implementation. This ensures your organization becomes:</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] text-center hover:border-primary/50 transition-all group">
                        <div class="mb-4 inline-block p-3 rounded-2xl bg-white/5 group-hover:bg-primary/20 transition-colors">
                            <Icon name="icon_11_clock" size={32} class="text-primary" animate={true} />
                        </div>
                        <p class="text-sm font-bold text-white">Faster in decision-making</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] text-center hover:border-primary/50 transition-all group">
                        <div class="mb-4 inline-block p-3 rounded-2xl bg-white/5 group-hover:bg-primary/20 transition-colors">
                            <Icon name="icon_22_menu" size={32} class="text-primary" animate={true} />
                        </div>
                        <p class="text-sm font-bold text-white">Adaptable to change</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] text-center hover:border-primary/50 transition-all group">
                        <div class="mb-4 inline-block p-3 rounded-2xl bg-white/5 group-hover:bg-primary/20 transition-colors">
                            <Icon name="icon_25_plus_add" size={32} class="text-primary" animate={true} />
                        </div>
                        <p class="text-sm font-bold text-white">Scalable & future-ready</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- AI-Enhanced -->
    <section class="py-24 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-4">AI-POWERED</span>
                    <h2 class="text-4xl font-bold font-headline mb-6">AI-Enhanced Consulting</h2>
                    <p class="text-on-surface-variant leading-relaxed font-light text-lg">We extend traditional consulting with artificial intelligence capabilities. This allows you to plan not only for today, but for the future.</p>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="bg-surface-container-low p-8 rounded-3xl border border-outline-variant/20 hover:border-primary/50 transition-all group">
                        <div class="text-primary mb-4 p-3 rounded-2xl bg-primary/5 inline-block group-hover:bg-primary/10 transition-colors">
                            <Icon name="icon_02_search" size={32} />
                        </div>
                        <h4 class="font-bold text-sm mb-1 uppercase tracking-wide">Decision Support</h4>
                        <p class="text-on-surface-variant text-xs font-light tracking-wide">Data-driven decision support</p>
                    </div>
                    <div class="bg-surface-container-low p-8 rounded-3xl border border-outline-variant/20 hover:border-primary/50 transition-all group">
                        <div class="text-primary mb-4 p-3 rounded-2xl bg-primary/5 inline-block group-hover:bg-primary/10 transition-colors">
                            <Icon name="icon_12_star" size={32} />
                        </div>
                        <h4 class="font-bold text-sm mb-1 uppercase tracking-wide">Smart Insights</h4>
                        <p class="text-on-surface-variant text-xs font-light tracking-wide">Intelligent process improvement</p>
                    </div>
                    <div class="bg-surface-container-low p-8 rounded-3xl border border-outline-variant/20 hover:border-primary/50 transition-all group">
                        <div class="text-primary mb-4 p-3 rounded-2xl bg-primary/5 inline-block group-hover:bg-primary/10 transition-colors">
                            <Icon name="icon_27_chart" size={32} />
                        </div>
                        <h4 class="font-bold text-sm mb-1 uppercase tracking-wide">Efficiency Analysis</h4>
                        <p class="text-on-surface-variant text-xs font-light tracking-wide">Operational efficiency analysis</p>
                    </div>
                    <div class="bg-surface-container-low p-8 rounded-3xl border border-outline-variant/20 hover:border-primary/50 transition-all group">
                        <div class="text-primary mb-4 p-3 rounded-2xl bg-primary/5 inline-block group-hover:bg-primary/10 transition-colors">
                            <Icon name="icon_05_settings" size={32} />
                        </div>
                        <h4 class="font-bold text-sm mb-1 uppercase tracking-wide">Automation</h4>
                        <p class="text-on-surface-variant text-xs font-light tracking-wide">Identifying automation opportunities</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Scope -->
    <section class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold font-headline mb-4 tracking-tight">Scope of Services</h2>
                <div class="w-12 h-1 bg-primary mx-auto"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 hover:shadow-2xl hover:border-primary/40 hover:-translate-y-2 transition-all text-center group">
                    <Icon name="icon_28_wifi" size={40} class="text-primary mb-6 mx-auto group-hover:scale-110 transition-transform" />
                    <h4 class="font-bold text-xs uppercase tracking-widest text-text-main">IT Strategy</h4>
                </div>
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 hover:shadow-2xl hover:border-primary/40 hover:-translate-y-2 transition-all text-center group">
                    <Icon name="icon_14_edit" size={40} class="text-primary mb-6 mx-auto group-hover:scale-110 transition-transform" />
                    <h4 class="font-bold text-xs uppercase tracking-widest text-text-main">Digital Transformation</h4>
                </div>
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 hover:shadow-2xl hover:border-primary/40 hover:-translate-y-2 transition-all text-center group">
                    <Icon name="icon_20_location" size={40} class="text-primary mb-6 mx-auto group-hover:scale-110 transition-transform" />
                    <h4 class="font-bold text-xs uppercase tracking-widest text-text-main">Roadmap Strategy</h4>
                </div>
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 hover:shadow-2xl hover:border-primary/40 hover:-translate-y-2 transition-all text-center group">
                    <Icon name="icon_05_settings" size={40} class="text-primary mb-6 mx-auto group-hover:scale-110 transition-transform" />
                    <h4 class="font-bold text-xs uppercase tracking-widest text-text-main">Process Optimization</h4>
                </div>
            </div>
        </div>
    </section>

    <!-- Thought Leadership (Premium Insight) -->
    <section class="py-24 md:py-32 px-8 md:px-12 bg-on-background text-white border-t border-white/5 overflow-hidden relative">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-primary/10 rounded-full blur-[100px]"></div>
        <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
            <div>
                <span class="text-primary text-xs font-semibold tracking-widest uppercase mb-4 block">THOUGHT LEADERSHIP</span>
                <h2 class="display-lg text-4xl md:text-5xl mb-6 font-headline leading-tight">CFO's Transformation Agenda</h2>
                <p class="text-white/60 text-lg leading-relaxed font-light mb-10 max-w-xl">
                    Discover how best-in-class financial operations are built, artificial intelligence integrations, and the architecture of time savings up to 40% in our special publication.
                </p>
                <a href="/harezm_cfo_ajandasi.pdf" target="_blank" class="group inline-flex items-center gap-4 bg-primary text-white px-10 py-5 rounded-2xl font-bold text-sm hover:shadow-2xl hover:-translate-y-1 transition-all">
                    Download Report
                    <Icon name="icon_16_download" size={20} class="group-hover:translate-y-1 transition-transform" />
                </a>
            </div>
            <div class="relative group">
                <div class="absolute inset-0 bg-primary/20 rounded-[3rem] blur-3xl group-hover:bg-primary/30 transition-all duration-700"></div>
                <div class="aspect-[4/3] rounded-[3rem] bg-white/5 border border-white/10 backdrop-blur-xl p-16 flex flex-col justify-between shadow-2xl overflow-hidden">
                    <div class="absolute top-0 right-0 p-8 opacity-20 group-hover:opacity-40 transition-opacity">
                         <Icon name="icon_22_menu" size={120} class="text-white" />
                    </div>
                    <div>
                        <Icon name="icon_23_large_language_model" size={60} class="text-primary mb-8" />
                        <h3 class="display-lg text-2xl md:text-4xl mb-4 leading-tight">AI-Supported Finance: Future Ops</h3>
                        <p class="text-white/50 font-light text-base leading-relaxed">SAP FI Transformation in 3 Months and End-to-End Cost Saving Case Studies.</p>
                    </div>
                    <div class="flex items-center gap-4 text-white/40 text-sm font-bold tracking-widest uppercase">
                         <Icon name="icon_24_check_done" size={16} /> Verified Strategy
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-8">
        <div class="max-w-5xl mx-auto">
            <div class="bg-surface-container-low rounded-[2.5rem] p-16 text-center relative overflow-hidden border border-outline-variant/20 shadow-xl">
                <h2 class="text-3xl md:text-5xl font-bold font-headline text-text-main mb-6 tracking-tight">Future-Proof Your Business</h2>
                <p class="text-xl text-on-surface-variant mb-12 max-w-2xl mx-auto font-light leading-relaxed">Accelerate your digital transformation with strategic consulting tailored to your industry.</p>
                <div class="flex justify-center">
                    <a href="/en/contact" class="group flex items-center gap-3 bg-primary text-white px-12 py-5 rounded-2xl font-bold hover:bg-primary/90 transition-all shadow-xl hover:-translate-y-1">
                        Contact Our Experts
                        <Icon name="icon_17_share" size={20} class="rotate-[-45deg] group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
