---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="Contact" lang={lang}>
    <section class="py-24 md:py-32 px-12 bg-surface">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
            <div>
                <h1 class="display-lg text-5xl font-semibold font-headline mb-6">Let's Evaluate the Right Approach</h1>
                <p class="text-xl text-on-surface-variant mb-12">Let's map out the most accurate financial transformation strategy tailored for you. Get in touch to discuss your corporate SAP and AI-driven finance objectives.</p>
                
                <ul class="space-y-6">
                    <li class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-primary/10 flex flex-col items-center justify-center text-primary">
                            <span class="material-symbols-outlined">location_on</span>
                        </div>
                        <div>
                            <h4 class="font-semibold">Address</h4>
                            <p class="text-on-surface-variant text-sm">Barbaros Mah. Mor Sumbul Sok. 5/A Deluxia Palace D:223 Atasehir, ISTANBUL</p>
                        </div>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-primary/10 flex flex-col items-center justify-center text-primary">
                            <span class="material-symbols-outlined">call</span>
                        </div>
                        <div>
                            <h4 class="font-semibold">Phone</h4>
                            <p class="text-on-surface-variant text-sm">+90 216 504 25 14</p>
                        </div>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-primary/10 flex flex-col items-center justify-center text-primary">
                            <span class="material-symbols-outlined">mail</span>
                        </div>
                        <div>
                            <h4 class="font-semibold">Email</h4>
                            <p class="text-on-surface-variant text-sm">info@harezm.com.tr</p>
                        </div>
                    </li>
                </ul>
            </div>
            
            <div class="bg-surface-container-lowest p-10 rounded-xl shadow-lg border border-outline-variant/10">
                <form class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold mb-2">Full Name</label>
                            <input type="text" class="w-full bg-surface-container rounded-md px-4 py-3 border-none ring-1 ring-outline-variant/20 focus:ring-primary outline-none" placeholder="Your Name">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2">Company</label>
                            <input type="text" class="w-full bg-surface-container rounded-md px-4 py-3 border-none ring-1 ring-outline-variant/20 focus:ring-primary outline-none" placeholder="Your Company">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2">Corporate Email</label>
                        <input type="email" class="w-full bg-surface-container rounded-md px-4 py-3 border-none ring-1 ring-outline-variant/20 focus:ring-primary outline-none" placeholder="corporate@email.com">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2">Project Type</label>
                        <select class="w-full bg-surface-container rounded-md px-4 py-3 border-none ring-1 ring-outline-variant/20 focus:ring-primary outline-none">
                            <option>Global Rollout ” Turkey Localization</option>
                            <option>Global Rollout ” International Operations</option>
                            <option>SAP FI/CO Consulting</option>
                            <option>SAP S/4HANA Migration</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2">Message</label>
                        <textarea rows="4" class="w-full bg-surface-container rounded-md px-4 py-3 border-none ring-1 ring-outline-variant/20 focus:ring-primary outline-none" placeholder="Briefly describe your project details..."></textarea>
                    </div>
                    <button type="button" class="w-full bg-primary text-on-primary py-4 rounded-md font-semibold hover:shadow-lg transition-all translateY(-4px) duration-300">Submit Inquiry</button>
                </form>
            </div>
        </div>
    </section>
</Layout>
