---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="Contact | Harezm" lang={lang}>
    <section class="pt-40 pb-32 px-8 bg-surface text-center">
        <div class="max-w-4xl mx-auto flex flex-col items-center">
            <span class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6">CONTACT US</span>
            <h1 class="display-lg text-5xl md:text-6xl font-bold font-headline mb-6 text-on-background">Let's Evaluate the Right Approach Together.</h1>
            <p class="text-xl text-on-surface-variant mb-16 leading-relaxed font-light max-w-2xl mx-auto">
                Let's plan the most accurate financial transformation strategy for you. Get in direct touch with our executives for your corporate SAP and AI-supported infrastructure goals.
            </p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 w-full">
                <!-- WhatsApp -->
                <a href="https://wa.me/905332388975" target="_blank" rel="noopener noreferrer" class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/30 hover:border-primary/50 hover:-translate-y-2 hover:shadow-xl transition-all group flex flex-col items-center justify-center text-center">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary mb-6 flex justify-center items-center group-hover:bg-[#25D366] group-hover:text-white transition-colors">
                        <svg class="w-8 h-8 fill-current text-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                    </div>
                    <h3 class="text-2xl font-bold font-headline text-on-background mb-3">WhatsApp</h3>
                    <p class="text-on-surface-variant text-sm font-medium tracking-wide group-hover:text-primary transition-colors">Send Message &rarr;</p>
                </a>
                
                <!-- Telegram -->
                <a href="https://t.me/+905332388975" target="_blank" rel="noopener noreferrer" class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/30 hover:border-primary/50 hover:-translate-y-2 hover:shadow-xl transition-all group flex flex-col items-center justify-center text-center">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary mb-6 flex justify-center items-center group-hover:bg-[#26A5E4] group-hover:text-white transition-colors">
                        <svg class="w-8 h-8 fill-current text-current" viewBox="0 0 24 24"><path d="m20.665 3.717-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785l3.019-14.228c.309-1.239-.473-1.8-1.282-1.434z"/></svg>
                    </div>
                    <h3 class="text-2xl font-bold font-headline text-on-background mb-3">Telegram</h3>
                    <p class="text-on-surface-variant text-sm font-medium tracking-wide group-hover:text-primary transition-colors">Text & Audio &rarr;</p>
                </a>

                <!-- LinkedIn -->
                <a href="https://www.linkedin.com/in/ilkerkaan/" target="_blank" rel="noopener noreferrer" class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/30 hover:border-[#0077b5]/50 hover:-translate-y-2 hover:shadow-xl transition-all group flex flex-col items-center justify-center text-center">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary mb-6 flex justify-center items-center group-hover:bg-[#0077b5] group-hover:text-white transition-colors">
                        <svg class="w-8 h-8 fill-current text-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </div>
                    <h3 class="text-2xl font-bold font-headline text-on-background mb-3">LinkedIn DM</h3>
                    <p class="text-on-surface-variant text-sm font-medium tracking-wide group-hover:text-primary transition-colors">Send a Message &rarr;</p>
                </a>
                
                <!-- Email -->
                <a href="mailto:info@harezm.com.tr" class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/30 hover:border-primary/50 hover:-translate-y-2 hover:shadow-xl transition-all group flex flex-col items-center justify-center text-center">
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary mb-6 flex justify-center items-center group-hover:bg-primary group-hover:text-white transition-colors">
                        <span class="material-symbols-outlined text-3xl">mail</span>
                    </div>
                    <h3 class="text-2xl font-bold font-headline text-on-background mb-3">Email</h3>
                    <p class="text-on-surface-variant text-sm font-medium tracking-wide group-hover:text-primary transition-colors">Official Inquiries &rarr;</p>
                </a>
            </div>
            
            <div class="mt-20 max-w-2xl mx-auto opacity-70 border-t border-outline-variant/20 pt-10">
                <p class="text-sm text-on-surface-variant italic mb-4">"Your messages are routed directly to our technical architects. Instead of a classic call center queue, you swiftly reach the right solution expert."</p>
            </div>
        </div>
    </section>
</Layout>
