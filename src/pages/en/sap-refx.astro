---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="SAP Real Estate Management (RE-FX)" lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6">SAP RE-FX</span>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">SAP Real Estate Management</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed">Manage your real estate portfolio from a single platform and optimize operations end-to-end.</p>
            </div>
        </div>
    </section>

    <!-- Intro -->
    <section class="py-20 bg-surface">
        <div class="max-w-5xl mx-auto px-8">
            <p class="text-lg text-on-surface-variant leading-relaxed mb-6">With SAP RE-FX, transform your real estate operations into a centralized, transparent, and efficient structure. Reduce manual work, minimize errors, and enable data-driven decision-making.</p>
            <p class="text-lg text-on-surface-variant leading-relaxed">Ideal for industries such as banking, retail, shopping malls, and real estate investment trusts, the solution delivers speed, control, and operational efficiency”while reducing time, cost, and resource usage.</p>
        </div>
    </section>

    <!-- What You Can Manage -->
    <section class="py-20 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8">
            <h2 class="text-3xl font-bold font-headline mb-12 text-center">What You Can Manage</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center group hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">real_estate_agent</span>
                    <h4 class="font-bold text-sm">Investment & Portfolio Management</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center group hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">square_foot</span>
                    <h4 class="font-bold text-sm">Space & Area-based Tracking</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center group hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">description</span>
                    <h4 class="font-bold text-sm">Lease Contracts & Escalation Terms</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center group hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">handshake</span>
                    <h4 class="font-bold text-sm">Ownership & Partnership Structures</h4>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center group hover:border-primary/50 transition-all">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4">engineering</span>
                    <h4 class="font-bold text-sm">Maintenance, Repair & Construction</h4>
                </div>
            </div>
        </div>
    </section>

    <!-- Industry Benefits -->
    <section class="py-20 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="bg-on-background text-white p-12 rounded-xl">
                    <span class="material-symbols-outlined text-primary-container text-4xl mb-6">account_balance</span>
                    <h3 class="text-2xl font-bold font-headline mb-6">For Banking</h3>
                    <p class="text-on-surface-variant mb-8">Gain full control over branch operations:</p>
                    <ul class="space-y-4 text-on-surface text-sm">
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary-container text-sm mt-0.5">check_circle</span>Branch renovation and project management</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary-container text-sm mt-0.5">check_circle</span>Lease and cost tracking</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary-container text-sm mt-0.5">check_circle</span>Space (sqm) and volume management</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary-container text-sm mt-0.5">check_circle</span>Penalties and periodic adjustments</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary-container text-sm mt-0.5">check_circle</span>Asset tracking and maintenance workflows</li>
                    </ul>
                </div>
                <div class="bg-primary text-white p-12 rounded-xl">
                    <span class="material-symbols-outlined text-4xl mb-6">storefront</span>
                    <h3 class="text-2xl font-bold font-headline mb-6">For Retail, Malls & REITs</h3>
                    <p class="text-white/70 mb-8">Simplify complex multi-tenant environments:</p>
                    <ul class="space-y-4 text-white/80 text-sm">
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-sm mt-0.5">check_circle</span>Sublease contracts and billing processes</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-sm mt-0.5">check_circle</span>Store opening and renovation workflows</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-sm mt-0.5">check_circle</span>Maintenance and repair for offices, malls, and residential</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-sm mt-0.5">check_circle</span>Lease tracking and cost control</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Financial Integration -->
    <section class="py-20 bg-surface-container-lowest">
        <div class="max-w-5xl mx-auto px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold font-headline mb-4">Integrated Financial Excellence</h2>
                <p class="text-on-surface-variant">SAP RE-FX integrates seamlessly with SAP FI (Financial Accounting) and CO (Controlling).</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">speed</span>
                    <h4 class="font-bold mb-2">Speed</h4>
                    <p class="text-on-surface-variant text-sm">Accelerate leasing and investment processes</p>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">analytics</span>
                    <h4 class="font-bold mb-2">Accurate Analysis</h4>
                    <p class="text-on-surface-variant text-sm">Perform accurate cost analysis</p>
                </div>
                <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/20 text-center">
                    <span class="material-symbols-outlined text-primary text-3xl mb-4">verified</span>
                    <h4 class="font-bold mb-2">Reliability</h4>
                    <p class="text-on-surface-variant text-sm">Manage valuation and financial transactions with confidence</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Strategic Value -->
    <section class="py-20 bg-surface">
        <div class="max-w-4xl mx-auto px-8 text-center">
            <h2 class="text-3xl font-bold font-headline mb-6">Less Manual Work, More Strategic Value</h2>
            <p class="text-on-surface-variant text-lg mb-12">Generate accurate, audit-ready reports. Optimize cost structures and automate repetitive workflows. Free up time to focus on high-value, strategic initiatives.</p>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
        <div class="max-w-5xl mx-auto px-8">
            <div class="bg-primary rounded-md p-12 text-center relative overflow-hidden">
                <h2 class="text-3xl font-bold font-headline text-white mb-4">Simplify Your Real Estate Operations</h2>
                <p class="text-white/70 mb-8">Gain control over costs and future-proof your real estate portfolio with SAP RE-FX.</p>
                <div class="flex justify-center">
                    <a href="/en/contact" class="bg-white text-primary px-8 py-3 rounded-md font-bold hover:bg-surface-container-low transition-colors shadow-lg">Contact Us</a>
                </div>
            </div>
        </div>
    </section>
</Layout>
