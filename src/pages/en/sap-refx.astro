---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const lang = 'en' as const;
---
<Layout title="SAP Real Estate Management (RE-FX)" lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6 border border-primary/20">
                     <Icon name="icon_01_home" size={14} class="opacity-70" />
                     SAP RE-FX
                </div>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">SAP Real Estate Management</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed max-w-2xl mx-auto">Manage your real estate portfolio from a single platform and optimize operations end-to-end.</p>
            </div>
        </div>
    </section>

    <!-- Intro -->
    <section class="py-20 bg-surface">
        <div class="max-w-5xl mx-auto px-8 text-center md:text-left">
            <p class="text-lg text-on-surface-variant leading-relaxed mb-6">With SAP RE-FX, transform your real estate operations into a centralized, transparent, and efficient structure. Reduce manual work, minimize errors, and enable data-driven decision-making.</p>
            <p class="text-lg text-on-surface-variant leading-relaxed font-light">Ideal for industries such as <strong class="text-primary font-bold">banking, retail, shopping malls, and real estate investment trusts</strong>, the solution delivers speed, control, and operational efficiency while reducing technical debt and resource usage.</p>
        </div>
    </section>

    <!-- What You Can Manage -->
    <section class="py-24 bg-surface-container-lowest overflow-hidden">
        <div class="max-w-7xl mx-auto px-8 relative">
            <div class="absolute -top-24 -left-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            <h2 class="text-3xl md:text-5xl font-bold font-headline mb-16 text-center tracking-tight">What You Can Manage</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
                {[
                    { icon: 'icon_02_search', title: 'Portfolio Management' },
                    { icon: 'icon_20_location', title: 'Area-based Tracking' },
                    { icon: 'icon_14_edit', title: 'Lease Contracts' },
                    { icon: 'icon_04_user', title: 'Ownership Structures' },
                    { icon: 'icon_05_settings', title: 'Maintenance & Construction' }
                ].map((item) => (
                    <div class="bg-surface-container-low p-10 rounded-[2rem] border border-outline-variant/20 text-center hover:shadow-2xl hover:border-primary/50 transition-all group">
                        <Icon name={item.icon} size={40} class="text-primary mb-6 mx-auto group-hover:scale-110 transition-transform" animate={true} />
                        <h4 class="font-bold text-xs uppercase tracking-widest leading-tight">{item.title}</h4>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Industry Benefits -->
    <section class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- For Banking -->
                <div class="bg-on-background text-white p-12 rounded-[3rem] relative overflow-hidden group hover:shadow-2xl transition-all duration-500">
                    <div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/10 rounded-full blur-[40px] group-hover:scale-125 transition-transform duration-700"></div>
                    <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mb-8 group-hover:rotate-6 transition-transform">
                        <Icon name="icon_01_home" size={32} class="text-primary-container" animate={true} />
                    </div>
                    <h3 class="text-3xl font-bold font-headline mb-6">For Banking</h3>
                    <p class="text-white/60 mb-8 border-b border-white/5 pb-4 font-light">Gain full control over branch operations and retail locations.</p>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-primary-container mt-0.5" />
                            <span class="text-sm font-light text-white/80 tracking-wide">Branch renovation & project management</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-primary-container mt-0.5" />
                            <span class="text-sm font-light text-white/80 tracking-wide">Lease & cost tracking with escalation clauses</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-primary-container mt-0.5" />
                            <span class="text-sm font-light text-white/80 tracking-wide">Space (sqm) & volume optimization</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-primary-container mt-0.5" />
                            <span class="text-sm font-light text-white/80 tracking-wide">Asset tracking & maintenance workflows</span>
                        </li>
                    </ul>
                </div>

                <!-- For Retail -->
                <div class="bg-primary text-white p-12 rounded-[3rem] relative overflow-hidden group hover:shadow-2xl transition-all duration-500">
                    <div class="absolute -top-12 -right-12 w-48 h-48 bg-white/10 rounded-full blur-[40px] group-hover:scale-125 transition-transform duration-700"></div>
                    <div class="w-16 h-16 bg-white/15 rounded-2xl flex items-center justify-center mb-8 group-hover:-rotate-6 transition-transform">
                        <Icon name="icon_22_menu" size={32} class="text-white" animate={true} />
                    </div>
                    <h3 class="text-3xl font-bold font-headline mb-6">For Retail & Malls</h3>
                    <p class="text-white/70 mb-8 border-b border-white/10 pb-4 font-light">Simplify complex multi-tenant environments and rental income.</p>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-white mt-0.5" />
                            <span class="text-sm font-light text-white/90 tracking-wide">Sublease contracts & automated billing</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-white mt-0.5" />
                            <span class="text-sm font-light text-white/90 tracking-wide">Store opening & renovation lifecycle</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-white mt-0.5" />
                            <span class="text-sm font-light text-white/90 tracking-wide">Maintenance & repair for multi-purpose assets</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <Icon name="icon_24_check_done" size={18} class="text-white mt-0.5" />
                            <span class="text-sm font-light text-white/90 tracking-wide">Multi-GAAP financial valuation support</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Financial Integration -->
    <section class="py-24 bg-surface-container-lowest">
        <div class="max-w-5xl mx-auto px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold font-headline mb-4 tracking-tight">Integrated Financial Excellence</h2>
                <div class="w-12 h-1 bg-primary mx-auto mb-4"></div>
                <p class="text-on-surface-variant font-light">SAP RE-FX integrates seamlessly with your central SAP FI/CO core.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all group">
                    <Icon name="icon_07_send" size={32} class="text-primary mb-4 mx-auto" animate={true} />
                    <h4 class="font-bold mb-2 uppercase tracking-widest text-xs">Speed</h4>
                    <p class="text-on-surface-variant text-sm font-light">Accelerate leasing cycles and investment rollout.</p>
                </div>
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all group">
                    <Icon name="icon_27_chart" size={32} class="text-primary mb-4 mx-auto" animate={true} />
                    <h4 class="font-bold mb-2 uppercase tracking-widest text-xs">Analysis</h4>
                    <p class="text-on-surface-variant text-sm font-light">Perform granular cost analysis per square meter.</p>
                </div>
                <div class="bg-surface-container-low p-10 rounded-3xl border border-outline-variant/20 text-center hover:border-primary/50 transition-all group">
                    <Icon name="icon_12_star" size={32} class="text-primary mb-4 mx-auto" animate={true} />
                    <h4 class="font-bold mb-2 uppercase tracking-widest text-xs">Reliability</h4>
                    <p class="text-on-surface-variant text-sm font-light">Manage valuation with localized legal compliance.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Value Statement -->
    <section class="py-24 bg-surface">
        <div class="max-w-4xl mx-auto px-8 text-center">
            <h2 class="text-3xl font-bold font-headline mb-6 tracking-tight">Less Manual Work, More Strategic Value</h2>
            <p class="text-on-surface-variant text-lg font-light leading-relaxed">Generate accurate, audit-ready reports. Optimize cost structures and automate repetitive workflows. Free up your finance team to focus on high-value, strategic initiatives.</p>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-8">
        <div class="max-w-5xl mx-auto">
            <div class="bg-on-background rounded-[3rem] p-16 text-center relative overflow-hidden border border-white/10 shadow-2xl">
                <div class="absolute -top-24 -left-24 w-64 h-64 bg-primary/20 rounded-full blur-[80px]"></div>
                <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-[80px]"></div>
                
                <h2 class="text-3xl md:text-5xl font-bold font-headline text-white mb-8 relative z-10">Simplify Your Operations</h2>
                <p class="text-xl text-white/50 mb-12 relative z-10 max-w-2xl mx-auto font-light leading-relaxed">Gain control over costs and future-proof your real estate portfolio with SAP RE-FX.</p>
                <div class="flex justify-center relative z-10">
                    <a href="/en/contact" class="group flex items-center gap-3 bg-primary text-white px-12 py-5 rounded-2xl font-bold hover:bg-primary/90 transition-all shadow-xl hover:-translate-y-1">
                        Contact Our Experts
                        <Icon name="icon_17_share" size={20} class="rotate-[-45deg] group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
