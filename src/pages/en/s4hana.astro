---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
const lang = 'en' as const;
---
<Layout title="S/4HANA Cloud Migration | Harezm" description="Expert S/4HANA transformation, cloud migration, and financial architecture services tailored for your enterprise." lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6 border border-primary/20">
                     <Icon name="icon_28_wifi" size={14} class="opacity-70" />
                     SAP S/4HANA CLOUD
                </div>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">S/4HANA Cloud Migration</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed max-w-2xl mx-auto">Unify all your business processes on a single cloud platform for maximum efficiency and speed.</p>
            </div>
        </div>
    </section>

    <!-- Grow vs Rise -->
    <section class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Grow -->
                <div class="bg-primary text-white p-12 rounded-[2.5rem] relative overflow-hidden group hover:shadow-2xl transition-all duration-500">
                    <div class="absolute -top-12 -right-12 w-48 h-48 bg-white/10 rounded-full blur-[40px] group-hover:scale-125 transition-transform duration-700"></div>
                    <span class="absolute top-8 right-8 px-4 py-1.5 bg-white/20 text-white rounded-full text-[10px] font-bold tracking-widest border border-white/20">PUBLIC EDITION</span>
                    
                    <div class="w-16 h-16 bg-white/15 rounded-2xl flex items-center justify-center mb-8 group-hover:rotate-6 transition-transform">
                        <Icon name="icon_28_wifi" size={32} class="text-white" animate={true} />
                    </div>
                    
                    <h3 class="text-3xl font-bold font-headline mb-3">Grow with SAP</h3>
                    <p class="text-sm text-white/60 mb-8 border-b border-white/10 pb-4">SAP S/4HANA Cloud Public Edition</p>
                    <p class="text-white/80 text-lg leading-relaxed mb-10 font-light">Cloud-based, scalable solution with rapid deployment for standard business processes.</p>
                    
                    <div class="space-y-4">
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_07_send" size={18} class="text-white/70" />
                            <span class="text-sm font-medium">Fast and easily scalable</span>
                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_18_lock" size={18} class="text-white/70" />
                            <span class="text-sm font-medium">Enterprise-grade security</span>
                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_11_clock" size={18} class="text-white/70" />
                            <span class="text-sm font-medium">Automatic regular updates</span>
                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_12_star" size={18} class="text-white/70" />
                            <span class="text-sm font-medium">Low total cost of ownership</span>
                        </div>
                    </div>
                </div>

                <!-- Rise -->
                <div class="bg-on-background text-white p-12 rounded-[2.5rem] relative overflow-hidden group hover:shadow-2xl transition-all duration-500 border border-white/5">
                    <div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/20 rounded-full blur-[40px] group-hover:scale-125 transition-transform duration-700"></div>
                    <span class="absolute top-8 right-8 px-4 py-1.5 bg-primary/20 text-primary-container rounded-full text-[10px] font-bold tracking-widest border border-primary/30">PRIVATE EDITION</span>
                    
                    <div class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mb-8 group-hover:-rotate-6 transition-transform">
                        <Icon name="icon_24_check_done" size={32} class="text-primary-container" animate={true} />
                    </div>
                    
                    <h3 class="text-3xl font-bold font-headline mb-3">Rise with SAP</h3>
                    <p class="text-sm text-white/40 mb-8 border-b border-white/10 pb-4">SAP S/4HANA Cloud Private Edition</p>
                    <p class="text-white/80 text-lg leading-relaxed mb-10 font-light">Fully customizable cloud solution with complete control, tailored to your needs.</p>
                    
                    <div class="space-y-4">
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_05_settings" size={18} class="text-primary-container/70" />
                            <span class="text-sm font-medium">Fully customizable to your needs</span>
                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_04_user" size={18} class="text-primary-container/70" />
                            <span class="text-sm font-medium">High-level data & process control</span>
                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_22_menu" size={18} class="text-primary-container/70" />
                            <span class="text-sm font-medium">Full compatibility with existing systems</span>
                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded-xl border border-white/10">
                            <Icon name="icon_18_lock" size={18} class="text-primary-container/70" />
                            <span class="text-sm font-medium">Dedicated data protection & security</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Methodology -->
    <section class="pb-24 bg-surface overflow-hidden">
        <div class="max-w-7xl mx-auto px-8">
            <div class="bg-surface-container-low rounded-[3rem] p-16 border border-outline-variant/20 relative">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div>
                        <h2 class="text-4xl font-bold font-headline mb-6 tracking-tight">Greenfield or Brownfield?<br/> <span class="text-primary">We guide you.</span></h2>
                        <p class="text-lg text-on-surface-variant font-light mb-8 leading-relaxed">Whether you are starting from scratch or migrating your legacy data, our certified experts ensure a seamless transition with zero business interruption.</p>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3 text-on-surface">
                                <Icon name="icon_24_check_done" size={20} class="text-teal" />
                                <span class="font-medium text-sm">Best-practice based workshops</span>
                            </li>
                            <li class="flex items-center gap-3 text-on-surface">
                                <Icon name="icon_24_check_done" size={20} class="text-teal" />
                                <span class="font-medium text-sm">Automated data migration tools</span>
                            </li>
                            <li class="flex items-center gap-3 text-on-surface">
                                <Icon name="icon_24_check_done" size={20} class="text-teal" />
                                <span class="font-medium text-sm">Post go-live hypercare support</span>
                            </li>
                        </ul>
                    </div>
                    <div class="relative">
                         <div class="absolute inset-0 bg-primary/10 rounded-[2rem] blur-2xl -rotate-6"></div>
                         <div class="relative bg-on-background p-10 rounded-[2rem] border border-white/5 shadow-2xl">
                             <div class="flex items-center gap-6 mb-8 text-white/40">
                                 <Icon name="icon_13_trash" size={40} class="rotate-[-12deg]" />
                                 <Icon name="icon_17_share" size={60} class="text-primary/40 rotate-[15deg]" />
                                 <Icon name="icon_05_settings" size={30} class="rotate-[-5deg]" />
                             </div>
                             <h4 class="text-2xl font-bold text-white mb-4">Architecture First</h4>
                             <p class="text-white/60 text-sm leading-relaxed font-light">We don't just migrate data; we re-architect your business processes for the cloud era, eliminating technical debt and manual bottlenecks.</p>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-8">
        <div class="max-w-5xl mx-auto">
            <div class="bg-primary rounded-[2.5rem] p-16 text-center relative overflow-hidden shadow-2xl">
                <div class="absolute -top-24 -left-24 w-64 h-64 bg-white/10 rounded-full blur-[80px]"></div>
                <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-white/10 rounded-full blur-[80px]"></div>
                
                <h2 class="text-3xl md:text-5xl font-bold font-headline text-white mb-8 relative z-10">Ready for the Cloud?</h2>
                <p class="text-xl text-white/70 mb-12 relative z-10 max-w-2xl mx-auto font-light leading-relaxed">Let's find the best S/4HANA model that perfectly fits your business scale and complexity.</p>
                <div class="flex justify-center relative z-10">
                    <a href="/en/contact" class="group flex items-center gap-3 bg-on-background text-white px-10 py-5 rounded-2xl font-bold hover:bg-black transition-all shadow-xl hover:-translate-y-1">
                        Contact Us Today
                        <Icon name="icon_17_share" size={20} class="rotate-[-45deg] group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
