---
import Layout from '../../layouts/Layout.astro';
const lang = 'en' as const;
---
<Layout title="S/4HANA Cloud Migration" lang={lang}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 bg-surface-container overflow-hidden">
        <div class="max-w-[1920px] mx-auto px-12 md:px-24">
            <div class="text-center max-w-4xl mx-auto">
                <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs tracking-widest uppercase mb-6">SAP S/4HANA CLOUD</span>
                <h1 class="text-5xl md:text-7xl font-bold font-headline text-on-background tracking-tight mb-8">S/4HANA Cloud Migration</h1>
                <p class="text-xl text-on-surface-variant font-body leading-relaxed">Unify all your business processes on a single cloud platform for maximum efficiency and speed.</p>
            </div>
        </div>
    </section>

    <!-- Grow vs Rise -->
    <section class="py-20 bg-surface">
        <div class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="bg-primary text-white p-12 rounded-xl relative overflow-hidden">
                    <span class="absolute top-6 right-6 px-3 py-1 bg-white/20 text-white rounded-full text-[10px] font-bold tracking-widest">PUBLIC EDITION</span>
                    <span class="material-symbols-outlined text-4xl mb-6">cloud</span>
                    <h3 class="text-2xl font-bold font-headline mb-2">Grow with SAP</h3>
                    <p class="text-sm text-white/60 mb-6">SAP S/4HANA Cloud Public Edition</p>
                    <p class="text-white/80 text-sm leading-relaxed mb-8">Cloud-based, scalable solution with rapid deployment for standard business processes.</p>
                    <div class="space-y-3">
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-sm">bolt</span><span class="text-sm">Fast and easily scalable</span></div>
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-sm">security</span><span class="text-sm">Enterprise-grade security</span></div>
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-sm">update</span><span class="text-sm">Automatic regular updates</span></div>
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-sm">savings</span><span class="text-sm">Low total cost of ownership</span></div>
                    </div>
                </div>
                <div class="bg-on-background text-white p-12 rounded-xl relative overflow-hidden">
                    <span class="absolute top-6 right-6 px-3 py-1 bg-primary-container/20 text-primary-container rounded-full text-[10px] font-bold tracking-widest">PRIVATE EDITION</span>
                    <span class="material-symbols-outlined text-primary-container text-4xl mb-6">cloud_done</span>
                    <h3 class="text-2xl font-bold font-headline mb-2">Rise with SAP</h3>
                    <p class="text-sm text-on-surface-variant mb-6">SAP S/4HANA Cloud Private Edition</p>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8">Fully customizable cloud solution with complete control, tailored to your needs.</p>
                    <div class="space-y-3 text-on-surface">
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary-container text-sm">tune</span><span class="text-sm">Fully customizable to your needs</span></div>
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary-container text-sm">admin_panel_settings</span><span class="text-sm">High-level data & process control</span></div>
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary-container text-sm">sync</span><span class="text-sm">Full compatibility with existing systems</span></div>
                        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-primary-container text-sm">lock</span><span class="text-sm">Dedicated data protection & security</span></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20">
        <div class="max-w-5xl mx-auto px-8">
            <div class="bg-primary rounded-md p-12 text-center">
                <h2 class="text-3xl font-bold font-headline text-white mb-4">Which Model Fits You?</h2>
                <p class="text-white/70 mb-8">Plan your S/4HANA migration with Greenfield or Brownfield approach.</p>
                <a href="/en/contact" class="bg-white text-primary px-8 py-3 rounded-md font-bold hover:bg-surface-container-low transition-colors shadow-lg">Contact Us</a>
            </div>
        </div>
    </section>
</Layout>
