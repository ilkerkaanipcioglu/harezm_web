---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  name: string;
  size?: number | string;
  class?: string;
  animate?: boolean;
}

const { 
  name, 
  size = 24, 
  class: className = '', 
  animate = false 
} = Astro.props;

// Construct path to the public icon
const iconPath = path.join(process.cwd(), 'public', 'icons', `${name}.svg`);

let svgContent = '';
try {
  svgContent = fs.readFileSync(iconPath, 'utf-8');
  
  // Clean up the SVG for inlining
  svgContent = svgContent
    .replace(/<svg[^>]*>/, '') // Remove opening tag to custom wrap
    .replace(/<\/svg>/, '')    // Remove closing tag
    .replace(/width="[^"]*"/g, '') // Remove hardcoded width
    .replace(/height="[^"]*"/g, ''); // Remove hardcoded height
} catch (err) {
  console.error(`❌ Icon not found: ${iconPath}`);
}
---

<div 
  class={`icon-container ${animate ? 'animate-wobble' : ''} ${className}`}
  style={`width: ${size}px; height: ${size}px;`}
>
  <svg 
    viewBox="0 0 500 500" 
    fill="none" 
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-full"
    set:html={svgContent}
  />
</div>

<style>
  .icon-container {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
    transition: transform 0.3s ease;
  }

  /* Signature Wobble Animation */
  .animate-wobble:hover {
    animation: wobble 0.5s ease-in-out infinite alternate;
  }

  @keyframes wobble {
    0% { transform: rotate(-2deg) scale(1); }
    100% { transform: rotate(2deg) scale(1.05); }
  }

  :global(.icon-container svg path) {
    stroke: currentColor;
  }

  /* Specific handling for our themed icons */
  :global(.icon-container .accent-path) {
    stroke: var(--accent) !important;
  }
</style>
