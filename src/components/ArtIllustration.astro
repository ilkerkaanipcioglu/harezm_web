---
/**
 * ArtIllustration — Aylık sergi illüstrasyon bileşeni
 * Absurd Design tarzı görselleri site renkleriyle gösterir.
 * 
 * V4.4 Palette Renkleri:
 *   brand    → #82165F Mürdüm (hue-rotate: 280deg)
 *   minimal  → Çok hafif mürdüm tint (düşük saturate)
 *   secondary→ #2DD4BF Teal (hue-rotate: 150deg)
 *   bw       → Siyah-beyaz (grayscale)
 */
export interface Props {
  src: string;
  alt?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  decorative?: boolean;
  variant?: 'brand' | 'minimal' | 'secondary' | 'bw';
}

const { 
  src, 
  alt = 'İllüstrasyon', 
  size = 'md', 
  class: className = '',
  decorative = false,
  variant = 'brand'
} = Astro.props;

const variantClass = `art-variant-${variant}`;
---

<div class={`art-illustration art-${size} ${variantClass} ${className}`} role={decorative ? 'presentation' : undefined}>
  <img 
    src={src} 
    alt={decorative ? '' : alt} 
    loading="lazy"
    aria-hidden={decorative ? 'true' : undefined}
  />
</div>

<style>
  .art-illustration {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .art-illustration:hover {
    transform: scale(1.04) rotate(-1deg);
  }

  .art-illustration img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: filter 0.4s ease;
  }

  /* === Variant Filters (V4.4 Palette) === */

  /* Brand: Mürdüm #82165F — ana renk, ama abartısız */
  .art-variant-brand img {
    filter: hue-rotate(280deg) saturate(1.2);
  }

  /* Minimal: Çok hafif mürdüm tint — neredeyse orijinal */
  .art-variant-minimal img {
    filter: hue-rotate(280deg) saturate(0.4) brightness(1.02);
  }

  /* Secondary: Teal #2DD4BF — 1-2 damla farklı renk */
  .art-variant-secondary img {
    filter: hue-rotate(150deg) saturate(0.8);
  }

  /* B&W: Siyah-beyaz — boyasız orijinal */
  .art-variant-bw img {
    filter: grayscale(1);
  }

  /* Boyutlar */
  .art-sm { width: 120px; height: 120px; }
  .art-md { width: 200px; height: 200px; }
  .art-lg { width: 320px; height: 320px; }
  .art-xl { width: 480px; height: 480px; }

  @media (max-width: 768px) {
    .art-sm { width: 80px; height: 80px; }
    .art-md { width: 140px; height: 140px; }
    .art-lg { width: 220px; height: 220px; }
    .art-xl { width: 320px; height: 320px; }
  }
</style>
